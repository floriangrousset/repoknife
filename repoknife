#============================================================================
# SECTION 12 — CLI DISPATCH, MENU, CHECKS, SELFTEST, MAIN
#============================================================================
#---------------------------------------------------------------- offer-to-fix
# Graceful failure layer. INVARIANT: only ever called from pre-check sites in
# the MAIN shell — never inside ui::spin, $(...) captures, or worker/batch code
# (auth logins are interactive foreground programs that need the real TTY).
# Fix commands are fixed literal allowlists — never interpolate remote strings.

fix::brew_pkg() {  # $1=tool → brew formula name (az is the only non-1:1)
  case "$1" in
    az) printf 'azure-cli' ;;
    *)  printf '%s' "$1" ;;
  esac
}

# Classify captured gh/git stderr into a stable category. PURE — no I/O;
# selftest drives it with canned strings. First match wins (order matters).
fix::classify_gh() {  # $1=stderr text → category on stdout
  case "$1" in
    *"command not found"*)                       printf 'missing' ;;
    *"gh auth login"*|*"not logged"*|*"HTTP 401"*|*authentication*) printf 'auth' ;;
    *"HTTP 403"*workflow*|*workflow*scope*|*"refresh -s workflow"*) printf 'scope' ;;
    *"API rate limit"*|*"rate limit exceeded"*)  printf 'ratelimit' ;;
    *"Could not resolve host"*|*"could not resolve host"*|*"connection refused"*|*"network is unreachable"*|*"timed out"*|*"i/o timeout"*) printf 'network' ;;
    *)                                           printf 'other' ;;
  esac
}

fix::gh_hint() {  # $1=category → "diagnosis|fix-cmd" (empty cmd = nothing to offer)
  case "$1" in
    missing)   printf 'GitHub CLI is not installed.|brew install gh' ;;
    auth)      printf 'GitHub CLI is not authenticated.|gh auth login' ;;
    scope)     printf "Your gh token lacks the 'workflow' scope.|gh auth refresh -s workflow" ;;
    ratelimit) printf 'GitHub API rate limit hit — wait a bit, or authenticate for a higher limit.|' ;;
    network)   printf 'Network error reaching GitHub — check your connection.|' ;;
    *)         printf '|' ;;
  esac
}

# Core offer-to-fix. set -e safe: every fallible call is guarded so a failing
# fix never kills the script.
#   $1=diagnosis  $2=fix command (fixed literal — shown verbatim AND executed)
#   $3=recheck command (optional; a leaf predicate, never a *::check wrapper)
#   $4=rc to return on give-up / plain mode (default 1)
# Returns 0 when fixed (recheck passes / fix succeeded), else $4.
fix::offer() {
  local diag="$1" fixcmd="$2" recheck="${3:-}" rc="${4:-1}"
  if ! ui::is_interactive; then
    log::err "$diag"
    log::info "    fix it with:  $fixcmd"
    return "$rc"
  fi
  ui::box "$C_YELLOW" "$diag" "" "Suggested fix:   $fixcmd"
  if ! ui::confirm "Run:  $fixcmd  ?" "Run it"; then
    log::info "    skipped — run it yourself when ready:  $fixcmd"
    return "$rc"
  fi
  # foreground TTY on purpose — auth logins are interactive, never ui::spin
  local frc=0
  eval "$fixcmd" || frc=$?
  if [ "$frc" -ne 0 ]; then
    ui::toast err "fix command exited $frc — run it manually:  $fixcmd"
    return "$rc"
  fi
  if [ -n "$recheck" ]; then
    if eval "$recheck" >/dev/null 2>&1; then ui::toast ok "fixed — continuing"; return 0
    else ui::toast warn "still not resolved — run it manually:  $fixcmd"; return "$rc"; fi
  fi
  ui::toast ok "done"
  return 0
}

# Dependency installer used by deps::check. Cannot use gum (gum may be the
# missing tool) — plain read -r y/N. brew missing → point at brew.sh, never
# install brew itself.
fix::offer_dep() {  # $1=tool ; rc 0 = present after the offer, 1 = still missing
  local tool="$1" pkg cmd
  pkg="$(fix::brew_pkg "$tool")"
  cmd="brew install $pkg"
  if ! command -v brew >/dev/null; then
    log::err "$tool is missing and Homebrew isn't installed."
    log::info "    install brew first:  https://brew.sh   then:  $cmd"
    return 1
  fi
  if ! ui::is_interactive; then
    log::err "$tool is not installed."
    log::info "    install it:  $cmd"
    return 1
  fi
  local ans=""
  printf '  %s is missing — run "%s" now? [y/N] ' "$tool" "$cmd" >&2
  read -r ans || true
  case "$ans" in
    y|Y|yes|YES) ;;
    *) log::info "    skipped — install it yourself:  $cmd"; return 1 ;;
  esac
  brew install "$pkg" || { log::err "install failed — run it manually:  $cmd"; return 1; }
  command -v "$tool" >/dev/null
}

# classify → hint → offer dispatcher for raw gh failures (post-mortem at the
# few interactive call sites that run gh outside the pre-checked flows).
fix::offer_gh_postmortem() {  # $1=captured stderr  $2=fallback toast message
  local cat pair diag cmd
  cat="$(fix::classify_gh "$1")"
  pair="$(fix::gh_hint "$cat")"
  diag="${pair%%|*}"; cmd="${pair#*|}"
  if [ -z "$cmd" ]; then ui::toast err "${diag:-$2}"; return 1; fi
  case "$cat" in
    auth)    fix::offer "$diag" "gh auth login" "gh auth status" 2 ;;
    missing) fix::offer "$diag" "brew install gh" "command -v gh" 1 ;;
    scope)   fix::offer "$diag" "gh auth refresh -s workflow" "auth::has_workflow_scope" 2 ;;
    *)       ui::toast err "${diag:-$2}"; return 1 ;;
  esac
}

deps::check() {
  local missing=() t
  for t in fzf jq gh git; do command -v "$t" >/dev/null || missing+=("$t"); done
  if ui::is_interactive; then
    command -v gum >/dev/null || missing+=(gum)
  fi
  [ "${#missing[@]}" -eq 0 ] && return 0
  printf '\n  repoknife needs a couple of tools:\n\n' >&2
  for t in git fzf jq gh gum az; do
    if command -v "$t" >/dev/null; then printf '    %s %s' "$G_OK" "$t" >&2; else printf '    %s %s' "$G_FAIL" "$t" >&2; fi
  done
  printf '\n\n' >&2
  # offer each missing tool (plain mode prints the exact command instead)
  local still=()
  for t in "${missing[@]}"; do
    fix::offer_dep "$t" || still+=("$t")
  done
  [ "${#still[@]}" -eq 0 ] && return 0
  log::err "still missing: ${still[*]}"
  exit 1
}

auth::check_gh() {
  gh auth status >/dev/null 2>&1 && return 0
  fix::offer "GitHub CLI is not authenticated — gh commands will fail. 'gh auth login' opens an interactive sign-in." \
             "gh auth login" "gh auth status" 2
}

auth::has_workflow_scope() {
  gh auth status 2>&1 | grep -q "workflow"
}

menu::counts() {
  local repos orgs provs dirtytxt=""
  repos="$(disco::local_repos | wc -l | tr -d ' ')"
  orgs="$( { disco::orgs github; disco::orgs azure-devops; disco::orgs gitlab; } | wc -l | tr -d ' ')"
  provs="$(disco::providers | wc -l | tr -d ' ')"
  if [ -f "$CACHE_DIR/counts.json" ]; then
    local at dirty attention
    at="$(jq -r '.at' "$CACHE_DIR/counts.json" 2>/dev/null || echo 0)"
    dirty="$(jq -r '.dirty' "$CACHE_DIR/counts.json" 2>/dev/null || echo '?')"
    attention="$(jq -r '.attention' "$CACHE_DIR/counts.json" 2>/dev/null || echo '?')"
    dirtytxt=" · $G_DIRTY $dirty dirty · $G_WARN $attention attention (cache $(ui::age "$at") ago)"
  else
    dirtytxt=" · (run health for status)"
  fi
  printf '📁 %s repos · %s orgs · %s providers%s' "$repos" "$orgs" "$provs" "$dirtytxt"
}

menu::loop() {
  # piped/CI invocation must never reach the bare gum calls below — gum is only
  # a hard dependency when interactive, so on a gum-less box this would die 127
  ui::is_interactive || { log::err "interactive menu unavailable in plain mode — use a subcommand (see --help)"; return 1; }
  ui::banner
  while :; do
    gum style --foreground "$C_DIM" --margin "0 0 1 2" "$(menu::counts)"
    local choice
    choice="$(ui::menu "" \
      "✨  Init       turn plain folders into gitflow repos" \
      "🔁  Sync       fetch + clone/pull repos from a provider" \
      "🔀  PRs        cross-repo pull-request dashboard" \
      "🤖  Actions    workflow runs · watch · rerun" \
      "💚  Health     scan every local repo for problems" \
      "🧹  Cleanup    prune gone/merged branches · sync develop" \
      "🔧  Config     orgs · ADO defaults · fork filter" \
      "📖  Help       keys · concepts · troubleshooting" \
      "👋  Quit")" || return 0
    case "$choice" in
      *Sync*)    mod::sync    || true ;;
      *PRs*)     mod::pr      || true ;;
      *Actions*) mod::runs    || true ;;
      *Health*)  mod::health  || true ;;
      *Cleanup*) mod::cleanup || true ;;
      *Init*)    mod::init    || true ;;
      *Config*)  mod::config  || true ;;
      *Help*)    mod::help    || true ;;
      *) return 0 ;;
    esac
  done
}

ver::print() {  # `--version`: always "repoknife X.Y.Z" (line 1, kept stable for the
  # brew formula test); on a dev checkout add a build line so an unreleased local
  # copy can't masquerade as the last release. VERSION is the last RELEASED version;
  # the release pipeline bumps it automatically — git describe shows how far ahead.
  printf 'repoknife %s\n' "$VERSION"
  command -v git >/dev/null || return 0
  local dir desc br
  dir="$(dirname "$SELF")"
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0
  # only annotate when THIS script is tracked by that repo — otherwise we're inside
  # an unrelated ENCLOSING checkout (e.g. a brew install under /opt/homebrew, which
  # is itself a git repo) and would leak ITS describe/branch (e.g. "5.1.15 · stable").
  git -C "$dir" ls-files --error-unmatch -- "$SELF" >/dev/null 2>&1 || return 0
  desc="$(git -C "$dir" describe --tags --always --dirty 2>/dev/null || true)"
  br="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  [ -n "$desc" ] && printf '  build  %s%s\n' "$desc" "${br:+ · $br}"
  return 0   # never let the trailing && be the failing leaf (set -e would abort --version)
}

cli::help() {
  cat <<EOF

   ╠══►  REPOKNIFE v$VERSION   a git-repos swiss-army-knife · by Florian Grousset

  USAGE
    repoknife                     launch interactive menu
    repoknife <command> [args] [flags]

  COMMANDS
    init                          gitflow-init plain folders (+ optional remote)
    sync     [org]                fetch + clone/pull from a provider
    pr       [scope]              PR dashboard · scope: all·mine·review·assigned·mentions
    runs     [org]                workflow runs · watch · rerun failed
    health                        scan every local repo for problems
    cleanup  [repo-path]          prune gone/merged branches · sync develop
    config   [list]               orgs · ADO defaults · fork filter

  FLAGS
    --org <org>        target org/account        --provider <p>   github|azure-devops|gitlab (gitlab = stub)
    --no-forks         exclude forks (sync)      --refresh        bypass the repo-list cache
    --dry-run          print actions, change nothing (honored by sync · init)
    --all              non-interactive: act on every actionable repo (sync)
    --plain            no color/TUI (auto when piped; alias --no-color; NO_COLOR honored)
    --exit-code        health: exit with the attention count (CI gate)
    -h --help          this screen                -V --version    print version

  CONVENTIONS
    <code-root>/github/<org>/<repo>
    <code-root>/gitlab/<org>/<project>/<repo>         project = subgroup · "No Project" if none
    <code-root>/azure-devops/<org>/<project>/<repo>   ADO (3-level)
    code root: ~/Code by default · config code_root · REPOKNIFE_CODE_ROOT env wins
    config:    ~/.repoknife.conf (installed) · repo-adjacent .repoknife.conf (dev runs)
    env:       REPOKNIFE_CFG_FILE (config path) · REPOKNIFE_CACHE_TTL (s, default 3600)
               REPOKNIFE_JOBS (parallel workers, default 8) · REPOKNIFE_NO_DISCOVER=1 (offline ADO)
    gitflow: main + develop (develop = default branch)

