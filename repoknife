}

cli::parse_args() {
  local args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --plain|--no-color) PLAIN=1 ;;
      --no-forks)         EXCLUDE_FORKS=1 ;;
      --dry-run)          DRY_RUN=1 ;;
      --all)              ALL=1 ;;
      --refresh)          REFRESH=1 ;;
      --exit-code)        USE_EXIT_CODE=1 ;;
      --org)              ARG_ORG="${2:?--org needs a value}"; shift ;;
      --org=*)            ARG_ORG="${1#*=}" ;;
      --provider)         ARG_PROVIDER="${2:?--provider needs a value}"; shift ;;
      --provider=*)       ARG_PROVIDER="${1#*=}" ;;
      -V|--version)       ver::print; exit 0 ;;
      -h|--help)          CMD=help; return 0 ;;
      --)                 shift; args+=("$@"); break ;;
      -*)                 printf 'unknown flag: %s (try --help)\n' "$1" >&2; exit 1 ;;
      *)                  args+=("$1") ;;
    esac
    shift
  done
  CMD="${args[0]:-}"
  CMD_ARGS=(${args[@]+"${args[@]:1}"})
}

# hidden helper: normalized repo list (used inside ui::spin so output is capturable)
cli::__list() { provider::dispatch "$1" list_repos "$2" ${3:+"$3"}; }

# hidden helpers: live ADO discovery (run inside ui::spin so output is capturable)
cli::__listprojects() { provider::dispatch azure-devops list_projects "$1"; }
cli::__listorgs()     { provider::dispatch azure-devops list_orgs; }

# hidden helper: fanout a worker verb over stdin items (used inside ui::spin)
cli::__fanout() { worker::fanout "$1"; }

# hidden helper: fzf preview panes
cli::__preview() {
  local kind="$1" key="${2:-}"
  palette::init
  case "$kind" in
    sync)
      [ -z "${REPOKNIFE_TSV:-}" ] && return 0
      key="${key#!}"
      local name fork arch empty defbranch pushed url desc provider org project
      read -r provider org project <<< "${REPOKNIFE_CTX:-}"
      while IFS=$'\t' read -r name fork arch empty defbranch pushed url desc; do
        [ "$name" = "$key" ] || continue
        printf '%s%s%s\n' "$A_BOLD" "$name" "$A_RST"
        printf '%s%s%s\n\n' "$A_FAINT" "──────────────────────────────────────" "$A_RST"
        # undo jq @tsv backslash-escaping for display (\t/\n can't appear:
        # control chars were gsub'd to spaces at ingestion — only \\ remains)
        desc="${desc//$'\\\\'/$'\\'}"
        [ -n "$desc" ] && printf '%s\n\n' "$desc"
        printf '  %sdefault%s  %s\n' "$A_DIM" "$A_RST" "$defbranch"
        printf '  %spushed%s   %s ago\n' "$A_DIM" "$A_RST" "$(ui::age "$pushed")"
        printf '  %sremote%s   %s\n' "$A_DIM" "$A_RST" "$url"
        [ "$fork" = 1 ] && printf '  %s%s fork%s\n' "$A_PURPLE" "$G_FORK" "$A_RST"
        [ "$arch" = 1 ] && printf '  %s%s archived%s\n' "$A_PURPLE" "$G_ARCH" "$A_RST"
        local rel dir
        if [ -n "$project" ]; then rel="$provider/$org/$project/$name"; else rel="$provider/$org/$name"; fi
        dir="$CODE_ROOT/$rel"
        printf '  %slocal%s    ' "$A_DIM" "$A_RST"
        if git::is_repo "$dir"; then
          printf '%s · branch %s · %s\n' "$rel" "$(git::current_branch "$dir")" \
            "$( [ "$(git::dirty_count "$dir")" -gt 0 ] && printf '%s%s dirty%s' "$A_YELLOW" "$G_DIRTY" "$A_RST" || printf '%sclean%s' "$A_GREEN" "$A_RST" )"
          printf '\n  %saction%s   PULL (ff-only, skip if dirty)\n' "$A_DIM" "$A_RST"
        else
          printf '%s%s not cloned%s\n' "$A_FAINT" "$G_NOTC" "$A_RST"
          printf '  %saction%s   CLONE → checkout develop (if present)\n' "$A_DIM" "$A_RST"
        fi
        return 0
      done < "$REPOKNIFE_TSV"
      ;;
    init)
      local rel="$key" dir files size
      dir="$CODE_ROOT/$rel"
      path::parse "$rel" || return 0
      files="$(find "$dir" -type f 2>/dev/null | wc -l | tr -d ' ')"
      size="$(du -sh "$dir" 2>/dev/null | cut -f1)"
      printf '%s%s%s\n' "$A_BOLD" "$(basename "$rel")" "$A_RST"
      printf '%s%s%s\n\n' "$A_FAINT" "──────────────────────────────────────" "$A_RST"
      printf '  %spath%s    %s/%s\n' "$A_DIM" "$A_RST" "$CODE_ROOT" "$rel"
      printf '  %sfiles%s   %s files · %s\n' "$A_DIM" "$A_RST" "$files" "$size"
      printf '  %sinfer%s   org = %s (%s)\n' "$A_DIM" "$A_RST" "$ORG" "$PROVIDER"
      if [ "$PROVIDER" = "github" ]; then
        printf '  %sremote%s  github.com/%s/%s (offered after init)\n' "$A_DIM" "$A_RST" "$ORG" "$REPO"
      else
        printf '  %sremote%s  (remote creation: github only in v1)\n' "$A_DIM" "$A_RST"
      fi
      printf '\n  %splan%s    git init -b main → commit → branch develop\n' "$A_DIM" "$A_RST"
      printf '          → checkout develop (gitflow default)\n'
      ;;
  esac
}

cli::dispatch() {
  case "$CMD" in
    # --- hidden fast-paths: no banner/deps/auth cost --------------------------
    _worker)        PLAIN=1; palette::init; worker::entry "${CMD_ARGS[@]}"; exit 0 ;;
    __list)         palette::init; cfg::load; cfg::bootstrap; cli::__list "${CMD_ARGS[@]}"; exit $? ;;
    __listprojects) palette::init; cfg::load; cfg::bootstrap; cli::__listprojects "${CMD_ARGS[@]}"; exit $? ;;
    __listorgs)     palette::init; cfg::load; cfg::bootstrap; cli::__listorgs; exit $? ;;
    __fanout)       palette::init; cfg::load; cfg::bootstrap; cli::__fanout "${CMD_ARGS[@]}"; exit $? ;;
    __initscan)     palette::init; disco::init_candidates; exit 0 ;;
    __prfetch)      pr::fetch "${CMD_ARGS[0]:-all}"; exit $? ;;
    __preview)      cli::__preview "${CMD_ARGS[@]}"; exit 0 ;;
    __createremote) palette::init; provider_github_create_repo "${CMD_ARGS[@]}"; exit $? ;;
    __syncdevelop)
      git -C "${CMD_ARGS[0]}" fetch -q --prune 2>/dev/null || true
      git -C "${CMD_ARGS[0]}" checkout -q develop && git -C "${CMD_ARGS[0]}" merge --no-edit -q "${CMD_ARGS[1]}"
      exit $? ;;
    _selftest)      selftest::run; exit $? ;;
  esac

  # freeze interactivity now, on the REAL stdin/stdout — before any $() capture
  if [ "$PLAIN" -eq 0 ] && [ -t 0 ] && [ -t 1 ]; then INTERACTIVE=1; fi
  palette::init
  # --provider is interpolated into provider_<p>_<verb> names and cache paths —
  # reject anything outside the known set before it reaches either
  if [ -n "$ARG_PROVIDER" ]; then
    case " ${PROVIDERS[*]} " in
      *" $ARG_PROVIDER "*) : ;;
      *) log::die "unknown provider: $ARG_PROVIDER (github · azure-devops · gitlab)" ;;
    esac
  fi
  deps::check
  cfg::load
  cfg::bootstrap
  cfg::firstrun
  [ "$(cfg::get exclude_forks_default)" = "true" ] && EXCLUDE_FORKS=1

  case "$CMD" in
    "")        menu::loop ;;
    sync)      mod::sync    ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    pr)        mod::pr      ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    runs)      mod::runs    ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    health)    mod::health  ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    cleanup)   mod::cleanup ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    init)      mod::init    ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    config)    mod::config  ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    help)      cli::help ;;
    *)         log::die "unknown command: $CMD (try --help)" ;;
  esac
}

#---------------------------------------------------------------- selftest
T_PASS=0; T_FAIL=0
t::check() {  # $1=name $2=expected $3=actual
  if [ "$2" = "$3" ]; then T_PASS=$((T_PASS+1)); printf 'PASS %s\n' "$1"
  else T_FAIL=$((T_FAIL+1)); printf 'FAIL %s\n  expected: %s\n  actual:   %s\n' "$1" "$2" "$3"; fi
}

# shellcheck disable=SC2015  # `A && t::check ok || t::check fail` is exact if/else: t::check always rc 0
selftest::run() {
  PLAIN=1; palette::init
  local fix; fix="$(tmp::dir)"
  # fixture tree
  mkdir -p "$fix/github/acme/widget/.git" \
           "$fix/github/acme/plainfolder" \
           "$fix/github/acme/.hidden/repo" \
           "$fix/github/.archive/legacy/.git" \
           "$fix/azure-devops/corp/Proj/api/.git" \
           "$fix/azure-devops/corp/Proj/scratch" \
           "$fix/gitlab/grp/No Project/tool/.git"
  CODE_ROOT="$fix"

  # --- path::repo_arity ---
  t::check "arity github" "2" "$(path::repo_arity github)"
  t::check "arity gitlab" "3" "$(path::repo_arity gitlab)"
  t::check "arity ado" "3" "$(path::repo_arity azure-devops)"
  t::check "arity unknown" "0" "$(path::repo_arity svn)"

  # --- path::parse ---
  path::parse "github/acme/widget" && t::check "parse gh ok" "github|acme||widget" "$PROVIDER|$ORG|$PROJECT|$REPO" \
    || t::check "parse gh ok" "rc0" "rc1"
  path::parse "$fix/azure-devops/corp/Proj/api" && t::check "parse ado ok" "azure-devops|corp|Proj|api" "$PROVIDER|$ORG|$PROJECT|$REPO" \
    || t::check "parse ado ok" "rc0" "rc1"
  path::parse "gitlab/grp/No Project/tool" && t::check "parse gitlab ok (space-safe)" "gitlab|grp|No Project|tool" "$PROVIDER|$ORG|$PROJECT|$REPO" \
    || t::check "parse gitlab ok (space-safe)" "rc0" "rc1"
  path::parse "github/acme" && t::check "parse org-level rejected" "rc1" "rc0" \
    || t::check "parse org-level rejected" "rc1" "rc1"
  path::parse "azure-devops/corp/Proj" && t::check "parse ado project-level rejected" "rc1" "rc0" \
    || t::check "parse ado project-level rejected" "rc1" "rc1"
  path::parse "gitlab/grp/tool" && t::check "parse gitlab 2-level rejected" "rc1" "rc0" \
    || t::check "parse gitlab 2-level rejected" "rc1" "rc1"
  path::parse "github/../escape" && t::check "parse traversal rejected" "rc1" "rc0" \
    || t::check "parse traversal rejected" "rc1" "rc1"
  path::parse "github/acme/.." && t::check "parse dotdot repo rejected" "rc1" "rc0" \
    || t::check "parse dotdot repo rejected" "rc1" "rc1"

  # --- org::valid (a leading '-' must not reach gh looking like a flag) ---
  org::valid acme         && t::check "org valid plain" "rc0" "rc0" || t::check "org valid plain" "rc0" "rc1"
  org::valid -foo         && t::check "org leading dash rejected" "rc1" "rc0" || t::check "org leading dash rejected" "rc1" "rc1"
  org::valid 'a b'        && t::check "org space rejected" "rc1" "rc0" || t::check "org space rejected" "rc1" "rc1"

  # --- cfg: allowlist + no code execution ---
  CFG_FILE="$fix/test.conf"
  local pwn="$fix/pwned"
  cat > "$CFG_FILE" <<EOF
# comment line
extra_orgs_github = acme, other-org
evil_key=\$(touch $pwn)
default_visibility=\$(touch $pwn)
ado_project_map=corp:Proj
EOF
  cfg::load 2>/dev/null
  t::check "cfg allowed key" "acme, other-org" "$(cfg::get extra_orgs_github)"
  t::check "cfg unknown key dropped" "" "$(cfg::get evil_key 2>/dev/null || true)"
  t::check "cfg no code execution" "absent" "$( [ -e "$pwn" ] && echo executed || echo absent )"
  t::check "cfg literal value kept" "\$(touch $pwn)" "$(cfg::get default_visibility)"
  t::check "cfg get default" "fallback" "$(cfg::get nonexistent_key fallback)"

  # --- cfg::set round-trip ---
  cfg::set default_visibility private
  cfg::load
  t::check "cfg set+reload" "private" "$(cfg::get default_visibility)"
  t::check "cfg set preserves others" "corp:Proj" "$(cfg::get ado_project_map)"
  t::check "conf template in sync" \
    "ado_default_org ado_project_map code_root default_visibility exclude_forks_default extra_orgs_azure-devops extra_orgs_github extra_orgs_gitlab" \
    "$(grep -Eo '^[a-z_-]+=' "$(dirname "$REPOKNIFE_SELF")/.repoknife.conf" | sed 's/=$//' | sort | tr '\n' ' ' | sed 's/ $//')"

  # --- release plumbing: VERSION parses (same grep release.yml uses) + guard string present ---
  t::check "VERSION parses for release" "$VERSION" \
    "$(grep -E '^VERSION="[0-9]+\.[0-9]+\.[0-9]+"' "$REPOKNIFE_SELF" | head -1 | sed -E 's/^VERSION="([^"]+)".*/\1/')"
  t::check "bash guard string present" "yes" \
    "$(grep -q 'requires bash >= 4.4' "$REPOKNIFE_SELF" && echo yes || echo no)"
  # guard the set -u/UTF-8 trap: a bare $var directly followed by a multibyte byte
  # (a $var butted against the ellipsis) makes bash fold the byte into the name →
  # unbound-variable abort. Always brace it: dollar-brace-var-brace then the ellipsis.
  # (perl is portable; BSD grep lacks -P, and [^ -~] would also flag legit TABs.)
  t::check "no bare \$var before a multibyte byte (set -u/UTF-8 trap)" "0" \
    "$(LC_ALL=C perl -ne '$n++ while /\$[A-Za-z_]\w*[^\x00-\x7f]/g; END{print $n+0}' "$REPOKNIFE_SELF")"

  # --- code_root: path::expand_tilde + cfg::bootstrap resolution ---
  # shellcheck disable=SC2088  # '~' / '~/x' are deliberate literal inputs to the expander under test
  t::check "expand_tilde bare"    "$HOME"     "$(path::expand_tilde '~')"
  # shellcheck disable=SC2088  # ditto — literal test input
  t::check "expand_tilde slash"   "$HOME/x"   "$(path::expand_tilde '~/x')"
  t::check "expand_tilde literal" "/abs/p"    "$(path::expand_tilde '/abs/p')"
  # bootstrap re-points CODE_ROOT from the code_root key (env not pinned)
  local r2="$fix/alt"; mkdir -p "$r2"
  CODE_ROOT="$fix"; CFG_FILE="$fix/rk.conf"; REPOKNIFE_ROOT_PINNED=0
  printf 'code_root=%s\n' "$r2" > "$CFG_FILE"
  cfg::load; cfg::bootstrap
  t::check "bootstrap re-points root" "$r2" "$CODE_ROOT"
  # env-pin wins over config code_root
  CODE_ROOT="$fix"; CFG_FILE="$fix/rk.conf"; REPOKNIFE_ROOT_PINNED=1
  printf 'code_root=%s\n' "$r2" > "$CFG_FILE"
  cfg::load; cfg::bootstrap
  t::check "bootstrap env-pin wins" "$fix" "$CODE_ROOT"
  # ~ in a code_root value expands (assert CODE_ROOT only — never load a real ~/.repoknife.conf)
  CODE_ROOT="$fix"; CFG_FILE="$fix/rk.conf"; REPOKNIFE_ROOT_PINNED=0
  printf 'code_root=~\n' > "$CFG_FILE"
  cfg::load; cfg::bootstrap
  t::check "bootstrap ~ expands" "$HOME" "$CODE_ROOT"
  # empty/absent code_root leaves the current root untouched
  CODE_ROOT="$fix"; CFG_FILE="$fix/rk.conf"; REPOKNIFE_ROOT_PINNED=0
  printf 'default_visibility=private\n' > "$CFG_FILE"
  cfg::load; cfg::bootstrap
  t::check "bootstrap no code_root keeps root" "$fix" "$CODE_ROOT"
  # restore fixture globals for the checks that follow
  CODE_ROOT="$fix"; CFG_FILE="$fix/test.conf"; REPOKNIFE_ROOT_PINNED=0; cfg::load 2>/dev/null

  # --- disco ---
  t::check "disco providers" "azure-devops github gitlab" "$(disco::providers | sort | tr '\n' ' ' | sed 's/ $//')"
  t::check "disco orgs union+dedup" "acme other-org" "$(disco::orgs github | tr '\n' ' ' | sed 's/ $//')"
  t::check "disco ado projects" "Proj" "$(disco::ado_projects corp | tr '\n' ' ' | sed 's/ $//')"
  # the template documents the SPACED map format — entries after a ", " must not vanish
  CFG[ado_project_map]='corp:Proj, corp:Other, other-org:X'
  t::check "disco ado projects (spaced map)" "Other Proj" "$(disco::ado_projects corp | tr '\n' ' ' | sed 's/ $//')"
  CFG[ado_project_map]='corp:Proj'
  t::check "disco local repos" "azure-devops/corp/Proj/api github/acme/widget gitlab/grp/No Project/tool" \
    "$(disco::local_repos | sort | tr '\n' ' ' | sed 's/ $//')"
  t::check "disco init candidates (depth-exact, no dotdirs)" \
    "azure-devops/corp/Proj/scratch github/acme/plainfolder" \
    "$(disco::init_candidates | sort | tr '\n' ' ' | sed 's/ $//')"

  # --- live ADO discovery wrappers (cache-aware; hermetic via a SEEDED cache — the
  #     non-interactive selftest never reaches the network path, and a guard env
  #     forces empty for defense-in-depth) ---
  mkdir -p "$fix/adocache"
  { printf '#fetched_at=%s\n' "$(date +%s)"; printf 'Apex\nBilling\nOrchestra\n'; } \
    > "$fix/adocache/azure-devops-projects__globalgig-devops.tsv"
  { printf '#fetched_at=%s\n' "$(date +%s)"; printf 'globalgig-devops\nflorian-grousset\n'; } \
    > "$fix/adocache/azure-devops-orgs__self.tsv"
  t::check "ado projects live (cache hit)" "Apex Billing Orchestra" \
    "$(CACHE_DIR="$fix/adocache" EXCLUDE_FORKS=0 REFRESH=0 disco::ado_projects_live globalgig-devops | tr '\n' ' ' | sed 's/ $//')"
  t::check "ado orgs live (cache hit)" "florian-grousset globalgig-devops" \
    "$(CACHE_DIR="$fix/adocache" EXCLUDE_FORKS=0 REFRESH=0 disco::ado_orgs_live | sort | tr '\n' ' ' | sed 's/ $//')"
  t::check "ado projects live guarded empty" "" \
    "$(CACHE_DIR="$fix/adocache" EXCLUDE_FORKS=0 REFRESH=0 REPOKNIFE_NO_DISCOVER=1 disco::ado_projects_live globalgig-devops)"
  t::check "ado orgs live guarded empty" "" \
    "$(CACHE_DIR="$fix/adocache" EXCLUDE_FORKS=0 REFRESH=0 REPOKNIFE_NO_DISCOVER=1 disco::ado_orgs_live)"

  # --- provider dispatch ---
  provider::dispatch github bogus_verb 2>/dev/null && t::check "dispatch missing verb" "rc1" "rc0" \
    || t::check "dispatch missing verb" "rc1" "rc1"

  # --- fix:: graceful failure layer (pure logic; interactive paths untestable) ---
  t::check "fix classify missing"   "missing"   "$(fix::classify_gh 'bash: gh: command not found')"
  t::check "fix classify auth"      "auth"      "$(fix::classify_gh 'To get started with GitHub CLI, please run: gh auth login')"
  t::check "fix classify 401"       "auth"      "$(fix::classify_gh 'HTTP 401: Bad credentials')"
  t::check "fix classify scope"     "scope"     "$(fix::classify_gh 'HTTP 403: token does not have the workflow scope')"
  t::check "fix classify ratelimit" "ratelimit" "$(fix::classify_gh 'API rate limit exceeded for user')"
  t::check "fix classify network"   "network"   "$(fix::classify_gh 'fatal: unable to access: Could not resolve host: github.com')"
  t::check "fix classify other"     "other"     "$(fix::classify_gh 'unexpected end of JSON input')"
  t::check "fix brew pkg gh"        "gh"        "$(fix::brew_pkg gh)"
  t::check "fix brew pkg az"        "azure-cli" "$(fix::brew_pkg az)"
  t::check "fix brew pkg gum"       "gum"       "$(fix::brew_pkg gum)"
  t::check "fix hint auth cmd"      "gh auth login"                "$(fix::gh_hint auth | cut -d'|' -f2)"
  t::check "fix hint scope cmd"     "gh auth refresh -s workflow"  "$(fix::gh_hint scope | cut -d'|' -f2)"
  t::check "fix hint ratelimit no-cmd" ""       "$(fix::gh_hint ratelimit | cut -d'|' -f2)"
  # plain-mode offer: runs nothing, prints the command, returns the original rc
  INTERACTIVE=0
  local fixout fixrc=0
  fixout="$(fix::offer 'test diag' "touch $fix/should_not_run" '' 7 2>&1)" || fixrc=$?
  t::check "fix offer plain rc preserved" "7" "$fixrc"
  t::check "fix offer plain no-run" "absent" "$( [ -e "$fix/should_not_run" ] && echo ran || echo absent )"
  t::check "fix offer plain prints cmd" "yes" "$(grep -q 'touch ' <<< "$fixout" && echo yes || echo no)"

  # --- ui:: pure formatters (column alignment + the terminal-injection defense) ---
  t::check "trunc fits"        "abc"  "$(ui::trunc abc 5)"
  t::check "trunc ellipsis"    "ab…"  "$(ui::trunc abcdef 3)"
  t::check "age zero sentinel" "?"    "$(ui::age 0)"
  t::check "age relative 2h"   "2h"   "$(ui::age "$(( $(date +%s) - 7200 ))")"
  t::check "strip_ansi OSC"    "X"    "$(printf '\033]0;pwn\007X' | ui::strip_ansi)"
  t::check "strip_ansi CSI"    "red"  "$(printf '\033[31mred\033[0m' | ui::strip_ansi)"
  # cursor-movement CSI followed by uppercase text: the old [ -\/] class spanned
  # space..BACKSLASH and ate the text after the sequence
  t::check "strip_ansi cursor CSI" "HELLO" "$(printf '\033[2AHELLO' | ui::strip_ansi)"
  # --version line 1 must stay exactly "repoknife X.Y.Z" (the brew formula test asserts it)
  t::check "version line shape" "yes" "$(v="$(ver::print)"; v="${v%%$'\n'*}"; [[ "$v" =~ ^repoknife[[:space:]][0-9]+\.[0-9]+\.[0-9]+$ ]] && echo yes || echo no)"

  # --- cache::file sanitization: config-supplied org/project must not escape CACHE_DIR ---
  t::check "cache key slash to _"   "$fix/c/github__a_b_c__x.tsv"   "$(CACHE_DIR="$fix/c" EXCLUDE_FORKS=0 cache::file github 'a/b/c' 'x')"
  t::check "cache key provider sanitized" "$fix/c/.._.._pwn__o.tsv" "$(CACHE_DIR="$fix/c" EXCLUDE_FORKS=0 cache::file '../../pwn' o '')"
  t::check "cache key no traversal" "$fix/c/github__.._.._etc.tsv" "$(CACHE_DIR="$fix/c" EXCLUDE_FORKS=0 cache::file github '../../etc' '')"
  t::check "cache key fork suffix"  "$fix/c/github__o__nofork.tsv" "$(CACHE_DIR="$fix/c" EXCLUDE_FORKS=1 cache::file github o '')"
  # live-discovery cache namespaces (fork suffix still appended under --no-forks — harmless duplication, locked here)
  t::check "cache key ado projects ns"   "$fix/c/azure-devops-projects__globalgig-devops.tsv"  "$(CACHE_DIR="$fix/c" EXCLUDE_FORKS=0 cache::file azure-devops-projects 'globalgig-devops' '')"
  t::check "cache key ado projects fork" "$fix/c/azure-devops-projects__o__nofork.tsv"          "$(CACHE_DIR="$fix/c" EXCLUDE_FORKS=1 cache::file azure-devops-projects o '')"
  t::check "cache key ado orgs ns"       "$fix/c/azure-devops-orgs__self.tsv"                   "$(CACHE_DIR="$fix/c" EXCLUDE_FORKS=0 cache::file azure-devops-orgs self '')"

  # --- TSV producer schemas (lock the 8-col repo-list & 7-col runs against drift) ---
  if command -v jq >/dev/null; then
    t::check "repo-list TSV cols" "8" \
      "$(printf '%s' '[{"name":"r","isFork":false,"isArchived":false,"isEmpty":false,"defaultBranchRef":{"name":"main"},"pushedAt":"2024-01-01T00:00:00Z","sshUrl":"git@x:o/r.git","description":"d\u0007e"}]' | jq -r "$JQ_REPO_LIST" | awk -F'\t' '{print NF; exit}')"
    t::check "repo-list cntrl stripped" "d e" \
      "$(printf '%s' '[{"name":"r","isFork":false,"isArchived":false,"isEmpty":false,"defaultBranchRef":null,"pushedAt":"-","sshUrl":"u","description":"d\u0007e"}]' | jq -r "$JQ_REPO_LIST" | cut -f8)"
    t::check "runs TSV cols" "7" \
      "$(printf '%s' '[{"databaseId":1,"status":"completed","conclusion":"success","displayTitle":"t","workflowName":"w","headBranch":"b","createdAt":"2024-01-01T00:00:00Z"}]' | jq -r --arg r 'o/r' "$JQ_RUNS" | awk -F'\t' '{print NF; exit}')"
    # empty mid-row fields must default to "-": tab is IFS whitespace, so an
    # empty field would collapse under `IFS=$'\t' read` and shift every column
    t::check "runs TSV empty fields default" "-|-" \
      "$(printf '%s' '[{"databaseId":1,"status":"completed","conclusion":"success","displayTitle":"t","workflowName":"","headBranch":null,"createdAt":"2024-01-01T00:00:00Z"}]' | jq -r --arg r 'o/r' "$JQ_RUNS" | awk -F'\t' '{print $4 "|" $5; exit}')"
    # ADO repo-list producer: 8 cols, cntrl-sanitized name, disabled filtered out
    t::check "ado repo-list TSV cols" "8" \
      "$(printf '%s' '[{"name":"r","isDisabled":false,"size":0,"defaultBranch":"refs/heads/main","sshUrl":"u"}]' | jq -r "$JQ_ADO_REPO_LIST" | awk -F'\t' '{print NF; exit}')"
    t::check "ado repo-list cntrl+disabled" "1:a b" \
      "$(printf '%s' '[{"name":"dead","isDisabled":true,"size":1,"sshUrl":"u"},{"name":"a\u0007b","size":1,"sshUrl":"u"}]' | jq -r "$JQ_ADO_REPO_LIST" | awk -F'\t' 'END{print NR":"$1}')"
    # PR-list producer: 3 cols, cntrl stripped from the title in the display row
    t::check "pr-list TSV cols" "3" \
      "$(printf '%s' '[{"number":7,"title":"t\u0007x","repository":{"name":"r","nameWithOwner":"o/r"},"isDraft":false,"author":{"login":"me"}}]' | jq -r --argjson tw 90 "$JQ_PR_LIST" | awk -F'\t' '{print NF; exit}')"
    # live-discovery producers: one name per line, control chars sanitized
    t::check "ado-projects names+cntrl" "2:a b" \
      "$(printf '%s' '{"value":[{"name":"Orchestra"},{"name":"a\u0007b"}]}' | jq -r "$JQ_ADO_PROJECTS" | awk 'NR==2{s=$0} END{print NR":"s}')"
    t::check "ado-orgs names+cntrl" "2:x y" \
      "$(printf '%s' '{"value":[{"accountName":"corp"},{"accountName":"x\u0007y"}]}' | jq -r "$JQ_ADO_ORGS" | awk 'NR==2{s=$0} END{print NR":"s}')"
  fi

  # --- worker dry/dispatch branches (pure) ---
  t::check "clone dry-run"           $'ok\tgithub/acme/new\tDRY: would clone' "$(DRY_RUN=1 worker::do_clone $'github/acme/new\turl\tmain')"
  t::check "syncitem unknown action" "error" "$(worker::do_syncitem $'bogus\tx' | cut -f1)"

  # --- batch renderer pure helpers (label extraction/truncation + window math) ---
  t::check "batch label clone item" "widget"  "$(batch::label $'clone\tgithub/acme/widget\turl\tmain')"
  t::check "batch label pull item"  "tool"    "$(batch::label $'pull\tgitlab/grp/No Project/tool')"
  t::check "batch label truncates"  "abcdefg…" "$(batch::label $'pull\tgithub/o/abcdefghij' 8)"
  t::check "winmath all fit"        "3 6"     "$(batch::winmath 10 3 6)"
  t::check "winmath inflight capped" "9 0"    "$(batch::winmath 10 20 50)"
  t::check "winmath done fills rest" "2 7"    "$(batch::winmath 10 2 50)"
  t::check "winmath tiny terminal"  "1 0"     "$(batch::winmath 1 5 5)"

  # --- worker fanout round-trip (xargs + item files preserve tabs) ---
  local fan
  fan="$(DRY_RUN=1 worker::fanout syncitem <<< $'pull\tgithub/acme/widget')"
  t::check "fanout tab round-trip" "ok	github/acme/widget	DRY: would pull" "$fan"

  # --- run-state flags exported so re-exec children (__list) inherit them (--no-forks fix) ---
  t::check "exclude_forks exported" "yes" "$(declare -p EXCLUDE_FORKS 2>/dev/null | grep -q 'declare -x' && echo yes || echo no)"
  t::check "plain exported"         "yes" "$(declare -p PLAIN         2>/dev/null | grep -q 'declare -x' && echo yes || echo no)"
  t::check "dry_run exported"       "yes" "$(declare -p DRY_RUN       2>/dev/null | grep -q 'declare -x' && echo yes || echo no)"

  # --- tmp::dir lives beneath the per-process root so the cleanup trap can reap it ---
  t::check "tmp dir under root" "yes" "$(d="$(tmp::dir)"; case "$d" in "$RK_TMP_ROOT"/*) echo yes ;; *) echo no ;; esac)"

  # --- cli args (safe to mutate globals: selftest exits right after) ---
  cli::parse_args --org acme sync --no-forks --dry-run extra
  t::check "args cmd" "sync" "$CMD"
  t::check "args org" "acme" "$ARG_ORG"
  t::check "args forks" "1" "$EXCLUDE_FORKS"
  t::check "args dry" "1" "$DRY_RUN"
  t::check "args positional" "extra" "${CMD_ARGS[0]:-}"
  DRY_RUN=0 EXCLUDE_FORKS=0

  # --- git helpers on a real fixture repo ---
  if command -v git >/dev/null; then
    local repo="$fix/github/acme/gitfix"
    git init -q -b main "$repo" 2>/dev/null
    ( cd "$repo" && git -c user.email=t@t -c user.name=t -c commit.gpgsign=false \
        commit -q --allow-empty -m init ) || true
    t::check "git current branch" "main" "$(git::current_branch "$repo")"
    t::check "git not empty" "no" "$(git::is_empty "$repo" && echo yes || echo no)"
    t::check "git dirty count clean" "0" "$(git::dirty_count "$repo")"
    t::check "git ahead/behind no upstream" "-	-" "$(git::ahead_behind "$repo")"
    t::check "git has develop (no)" "no" "$(git::has_branch "$repo" develop && echo yes || echo no)"
    git -C "$repo" branch develop
    t::check "git has develop (yes)" "yes" "$(git::has_branch "$repo" develop && echo yes || echo no)"
    t::check "git fetch age never" "never" "$(git::fetch_age "$repo")"
    # status worker row shape (10 TSV fields)
    local row; row="$(worker::do_status "github/acme/gitfix")"
    t::check "status row fields" "10" "$(awk -F'\t' '{print NF}' <<< "$row")"
    t::check "status row label" "ok" "$(cut -f10 <<< "$row")"
    # syncstate worker row shape (4 TSV fields) — lock the new schema (clean fixture)
    local srow; srow="$(worker::do_syncstate "github/acme/gitfix")"
    t::check "syncstate row fields" "4" "$(awk -F'\t' '{print NF}' <<< "$srow")"
    # rank ladder: a staged change → dirty (rank 1). The precedence is data-safety-critical
    # (a diverged/dirty repo mis-ranked as ok is exactly what health must never do).
    printf 'x\n' > "$repo/dirtyfile"; git -C "$repo" add dirtyfile
    local drow; drow="$(worker::do_status "github/acme/gitfix")"
    t::check "status rank dirty"  "1"     "$(cut -f9  <<< "$drow")"
    t::check "status label dirty" "dirty" "$(cut -f10 <<< "$drow")"
    # do_pull refuses a dirty tree (gotcha #11: skipped, never autostashed) before any pull
    t::check "pull skips dirty" "skip" "$(DRY_RUN=0 worker::do_pull github/acme/gitfix | cut -f1)"
    # a repo with no develop branch → rank 2
    local repo2="$fix/github/acme/nodev"
    git init -q -b main "$repo2" 2>/dev/null
    ( cd "$repo2" && git -c user.email=t@t -c user.name=t -c commit.gpgsign=false commit -q --allow-empty -m init ) || true
    t::check "status rank no-develop" "2" "$(cut -f9 <<< "$(worker::do_status github/acme/nodev)")"
    # git::merged_into: a branch at main is an ancestor (merged); a branch ahead is not
    git -C "$repo2" branch feat
    git::merged_into "$repo2" feat main && t::check "merged_into ancestor" "yes" "yes" || t::check "merged_into ancestor" "yes" "no"
    ( cd "$repo2" && git checkout -q feat && git -c user.email=t@t -c user.name=t -c commit.gpgsign=false commit -q --allow-empty -m ahead && git checkout -q main ) || true
    git::merged_into "$repo2" feat main && t::check "merged_into not-merged" "no" "yes" || t::check "merged_into not-merged" "no" "no"

    # --- git::branch_rows trackclass ladder (guards branch deletion in cleanup) ---
    # local bare "remote" → sync / gone / "ahead 1" / local all on one fixture
    local bare="$fix/remote.git" repo3="$fix/github/acme/tracked"
    git init -q --bare "$bare"
    git init -q -b main "$repo3"
    ( cd "$repo3" \
      && git remote add origin "$bare" \
      && git -c user.email=t@t -c user.name=t -c commit.gpgsign=false commit -q --allow-empty -m init \
      && git push -q -u origin main \
      && git checkout -q -b feat-gone && git push -q -u origin feat-gone && git checkout -q main \
      && git push -q origin :feat-gone && git fetch -q -p \
      && git checkout -q -b ahead1 && git push -q -u origin ahead1 \
      && git -c user.email=t@t -c user.name=t -c commit.gpgsign=false commit -q --allow-empty -m more \
      && git checkout -q main \
      && git branch -q localb ) || true
    t::check "branch_rows trackclasses" "ahead1:ahead 1 feat-gone:gone localb:local main:sync" \
      "$(git::branch_rows "$repo3" | awk -F'\t' '{print $1 ":" $3}' | sort | tr '\n' ' ' | sed 's/ $//')"

    # --- worker::do_status EMPTY/unborn row: 10 cols, rank 7, symbolic-ref name ---
    # (rev-parse lies "HEAD" on an unborn branch — the row must carry the real name)
    local repo4="$fix/github/acme/unborn" erow
    git init -q -b trunk "$repo4"
    erow="$(worker::do_status "github/acme/unborn")"
    t::check "status EMPTY row fields" "10" "$(awk -F'\t' '{print NF}' <<< "$erow")"
    t::check "status EMPTY rank+label" "7|EMPTY" "$(awk -F'\t' '{print $9 "|" $10}' <<< "$erow")"
    t::check "status EMPTY branch name" "trunk" "$(cut -f2 <<< "$erow")"
  fi

  printf '\n%d passed, %d failed\n' "$T_PASS" "$T_FAIL"
  [ "$T_FAIL" -eq 0 ]
}

#---------------------------------------------------------------- main
main() {
  cli::parse_args "$@"
  cli::dispatch
}

main "$@"
