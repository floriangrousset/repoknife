cli::parse_args() {
  local args=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --plain|--no-color) PLAIN=1 ;;
      --no-forks)         EXCLUDE_FORKS=1 ;;
      --dry-run)          DRY_RUN=1 ;;
      --all)              ALL=1 ;;
      --refresh)          REFRESH=1 ;;
      --exit-code)        USE_EXIT_CODE=1 ;;
      --org)              ARG_ORG="${2:?--org needs a value}"; shift ;;
      --org=*)            ARG_ORG="${1#*=}" ;;
      --provider)         ARG_PROVIDER="${2:?--provider needs a value}"; shift ;;
      --provider=*)       ARG_PROVIDER="${1#*=}" ;;
      -V|--version)       printf 'repoknife %s\n' "$VERSION"; exit 0 ;;
      -h|--help)          CMD=help; return 0 ;;
      --)                 shift; args+=("$@"); break ;;
      -*)                 printf 'unknown flag: %s (try --help)\n' "$1" >&2; exit 1 ;;
      *)                  args+=("$1") ;;
    esac
    shift
  done
  CMD="${args[0]:-}"
  CMD_ARGS=(${args[@]+"${args[@]:1}"})
}

# hidden helper: normalized repo list (used inside ui::spin so output is capturable)
cli::__list() { provider::dispatch "$1" list_repos "$2" ${3:+"$3"}; }

# hidden helper: fanout a worker verb over stdin items (used inside ui::spin)
cli::__fanout() { worker::fanout "$1"; }

# hidden helper: fzf preview panes
cli::__preview() {
  local kind="$1" key="${2:-}"
  palette::init
  case "$kind" in
    sync)
      [ -z "${REPOKNIFE_TSV:-}" ] && return 0
      key="${key#!}"
      local name fork arch empty defbranch pushed url desc provider org project
      read -r provider org project <<< "${REPOKNIFE_CTX:-}"
      while IFS=$'\t' read -r name fork arch empty defbranch pushed url desc; do
        [ "$name" = "$key" ] || continue
        printf '%s%s%s\n' "$A_BOLD" "$name" "$A_RST"
        printf '%s%s%s\n\n' "$A_FAINT" "──────────────────────────────────────" "$A_RST"
        [ -n "$desc" ] && printf '%s\n\n' "$desc"
        printf '  %sdefault%s  %s\n' "$A_DIM" "$A_RST" "$defbranch"
        printf '  %spushed%s   %s ago\n' "$A_DIM" "$A_RST" "$(ui::age "$pushed")"
        printf '  %sremote%s   %s\n' "$A_DIM" "$A_RST" "$url"
        [ "$fork" = 1 ] && printf '  %s%s fork%s\n' "$A_PURPLE" "$G_FORK" "$A_RST"
        [ "$arch" = 1 ] && printf '  %s%s archived%s\n' "$A_PURPLE" "$G_ARCH" "$A_RST"
        local rel dir
        if [ -n "$project" ]; then rel="$provider/$org/$project/$name"; else rel="$provider/$org/$name"; fi
        dir="$CODE_ROOT/$rel"
        printf '  %slocal%s    ' "$A_DIM" "$A_RST"
        if git::is_repo "$dir"; then
          printf '%s · branch %s · %s\n' "$rel" "$(git::current_branch "$dir")" \
            "$( [ "$(git::dirty_count "$dir")" -gt 0 ] && printf '%s%s dirty%s' "$A_YELLOW" "$G_DIRTY" "$A_RST" || printf '%sclean%s' "$A_GREEN" "$A_RST" )"
          printf '\n  %saction%s   PULL (ff-only, skip if dirty)\n' "$A_DIM" "$A_RST"
        else
          printf '%s%s not cloned%s\n' "$A_FAINT" "$G_NOTC" "$A_RST"
          printf '  %saction%s   CLONE → checkout develop (if present)\n' "$A_DIM" "$A_RST"
        fi
        return 0
      done < "$REPOKNIFE_TSV"
      ;;
    init)
      local rel="$key" dir files size
      dir="$CODE_ROOT/$rel"
      path::parse "$rel" || return 0
      files="$(find "$dir" -type f 2>/dev/null | wc -l | tr -d ' ')"
      size="$(du -sh "$dir" 2>/dev/null | cut -f1)"
      printf '%s%s%s\n' "$A_BOLD" "$(basename "$rel")" "$A_RST"
      printf '%s%s%s\n\n' "$A_FAINT" "──────────────────────────────────────" "$A_RST"
      printf '  %spath%s    ~/Code/%s\n' "$A_DIM" "$A_RST" "$rel"
      printf '  %sfiles%s   %s files · %s\n' "$A_DIM" "$A_RST" "$files" "$size"
      printf '  %sinfer%s   org = %s (%s)\n' "$A_DIM" "$A_RST" "$ORG" "$PROVIDER"
      if [ "$PROVIDER" = "github" ]; then
        printf '  %sremote%s  github.com/%s/%s (offered after init)\n' "$A_DIM" "$A_RST" "$ORG" "$REPO"
      else
        printf '  %sremote%s  (remote creation: github only in v1)\n' "$A_DIM" "$A_RST"
      fi
      printf '\n  %splan%s    git init -b main → commit → branch develop\n' "$A_DIM" "$A_RST"
      printf '          → checkout develop (gitflow default)\n'
      ;;
  esac
}

cli::dispatch() {
  case "$CMD" in
    # --- hidden fast-paths: no banner/deps/auth cost --------------------------
    _worker)        PLAIN=1; palette::init; worker::entry "${CMD_ARGS[@]}"; exit 0 ;;
    __list)         palette::init; cfg::load; cli::__list "${CMD_ARGS[@]}"; exit $? ;;
    __fanout)       palette::init; cfg::load; cli::__fanout "${CMD_ARGS[@]}"; exit $? ;;
    __initscan)     palette::init; disco::init_candidates; exit 0 ;;
    __prfetch)      pr::fetch "${CMD_ARGS[0]:-all}"; exit $? ;;
    __preview)      cli::__preview "${CMD_ARGS[@]}"; exit 0 ;;
    __createremote) palette::init; provider_github_create_repo "${CMD_ARGS[@]}"; exit $? ;;
    __syncdevelop)
      git -C "${CMD_ARGS[0]}" fetch -q --prune 2>/dev/null || true
      git -C "${CMD_ARGS[0]}" checkout -q develop && git -C "${CMD_ARGS[0]}" merge --no-edit -q "${CMD_ARGS[1]}"
      exit $? ;;
    _selftest)      selftest::run; exit $? ;;
  esac

  # freeze interactivity now, on the REAL stdin/stdout — before any $() capture
  if [ "$PLAIN" -eq 0 ] && [ -t 0 ] && [ -t 1 ]; then INTERACTIVE=1; fi
  palette::init
  deps::check
  cfg::load
  [ "$(cfg::get exclude_forks_default)" = "true" ] && EXCLUDE_FORKS=1

  case "$CMD" in
    "")        menu::loop ;;
    sync)      mod::sync    ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    pr)        mod::pr      ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    runs)      mod::runs    ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    health)    mod::health  ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    cleanup)   mod::cleanup ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    init)      mod::init    ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    config)    mod::config  ${CMD_ARGS[@]+"${CMD_ARGS[@]}"} ;;
    help)      cli::help ;;
    *)         log::die "unknown command: $CMD (try --help)" ;;
  esac
}

#---------------------------------------------------------------- selftest
T_PASS=0; T_FAIL=0
t::check() {  # $1=name $2=expected $3=actual
  if [ "$2" = "$3" ]; then T_PASS=$((T_PASS+1)); printf 'PASS %s\n' "$1"
  else T_FAIL=$((T_FAIL+1)); printf 'FAIL %s\n  expected: %s\n  actual:   %s\n' "$1" "$2" "$3"; fi
}

# shellcheck disable=SC2015  # `A && t::check ok || t::check fail` is exact if/else: t::check always rc 0
selftest::run() {
  PLAIN=1; palette::init
  local fix; fix="$(tmp::dir)"
  # fixture tree
  mkdir -p "$fix/github/acme/widget/.git" \
           "$fix/github/acme/plainfolder" \
           "$fix/github/acme/.hidden/repo" \
           "$fix/azure-devops/corp/Proj/api/.git" \
           "$fix/azure-devops/corp/Proj/scratch" \
           "$fix/gitlab/grp/No Project/tool/.git"
  CODE_ROOT="$fix"

  # --- path::repo_arity ---
  t::check "arity github" "2" "$(path::repo_arity github)"
  t::check "arity gitlab" "3" "$(path::repo_arity gitlab)"
  t::check "arity ado" "3" "$(path::repo_arity azure-devops)"
  t::check "arity unknown" "0" "$(path::repo_arity svn)"

  # --- path::parse ---
  path::parse "github/acme/widget" && t::check "parse gh ok" "github|acme||widget" "$PROVIDER|$ORG|$PROJECT|$REPO" \
    || t::check "parse gh ok" "rc0" "rc1"
  path::parse "$fix/azure-devops/corp/Proj/api" && t::check "parse ado ok" "azure-devops|corp|Proj|api" "$PROVIDER|$ORG|$PROJECT|$REPO" \
    || t::check "parse ado ok" "rc0" "rc1"
  path::parse "gitlab/grp/No Project/tool" && t::check "parse gitlab ok (space-safe)" "gitlab|grp|No Project|tool" "$PROVIDER|$ORG|$PROJECT|$REPO" \
    || t::check "parse gitlab ok (space-safe)" "rc0" "rc1"
  path::parse "github/acme" && t::check "parse org-level rejected" "rc1" "rc0" \
    || t::check "parse org-level rejected" "rc1" "rc1"
  path::parse "azure-devops/corp/Proj" && t::check "parse ado project-level rejected" "rc1" "rc0" \
    || t::check "parse ado project-level rejected" "rc1" "rc1"
  path::parse "gitlab/grp/tool" && t::check "parse gitlab 2-level rejected" "rc1" "rc0" \
    || t::check "parse gitlab 2-level rejected" "rc1" "rc1"
  path::parse "github/../escape" && t::check "parse traversal rejected" "rc1" "rc0" \
    || t::check "parse traversal rejected" "rc1" "rc1"
  path::parse "github/acme/.." && t::check "parse dotdot repo rejected" "rc1" "rc0" \
    || t::check "parse dotdot repo rejected" "rc1" "rc1"

  # --- cfg: allowlist + no code execution ---
  CFG_FILE="$fix/test.conf"
  local pwn="$fix/pwned"
  cat > "$CFG_FILE" <<EOF
# comment line
extra_orgs_github = acme, other-org
evil_key=\$(touch $pwn)
default_visibility=\$(touch $pwn)
ado_project_map=corp:Proj
EOF
  cfg::load 2>/dev/null
  t::check "cfg allowed key" "acme, other-org" "$(cfg::get extra_orgs_github)"
  t::check "cfg unknown key dropped" "" "$(cfg::get evil_key 2>/dev/null || true)"
  t::check "cfg no code execution" "absent" "$( [ -e "$pwn" ] && echo executed || echo absent )"
  t::check "cfg literal value kept" "\$(touch $pwn)" "$(cfg::get default_visibility)"
  t::check "cfg get default" "fallback" "$(cfg::get nonexistent_key fallback)"

  # --- cfg::set round-trip ---
  cfg::set default_visibility private
  cfg::load
  t::check "cfg set+reload" "private" "$(cfg::get default_visibility)"
  t::check "cfg set preserves others" "corp:Proj" "$(cfg::get ado_project_map)"
  t::check "conf template in sync" \
    "ado_default_org ado_project_map default_visibility exclude_forks_default extra_orgs_azure-devops extra_orgs_github extra_orgs_gitlab" \
    "$(grep -Eo '^[a-z_-]+=' "$(dirname "$REPOKNIFE_SELF")/.repoknife.conf" | sed 's/=$//' | sort | tr '\n' ' ' | sed 's/ $//')"

  # --- disco ---
  t::check "disco providers" "azure-devops github gitlab" "$(disco::providers | sort | tr '\n' ' ' | sed 's/ $//')"
  t::check "disco orgs union+dedup" "acme other-org" "$(disco::orgs github | tr '\n' ' ' | sed 's/ $//')"
  t::check "disco ado projects" "Proj" "$(disco::ado_projects corp | tr '\n' ' ' | sed 's/ $//')"
  t::check "disco local repos" "azure-devops/corp/Proj/api github/acme/widget gitlab/grp/No Project/tool" \
    "$(disco::local_repos | sort | tr '\n' ' ' | sed 's/ $//')"
  t::check "disco init candidates (depth-exact, no dotdirs)" \
    "azure-devops/corp/Proj/scratch github/acme/plainfolder" \
    "$(disco::init_candidates | sort | tr '\n' ' ' | sed 's/ $//')"

  # --- provider dispatch ---
  provider::dispatch github bogus_verb 2>/dev/null && t::check "dispatch missing verb" "rc1" "rc0" \
    || t::check "dispatch missing verb" "rc1" "rc1"

  # --- worker fanout round-trip (xargs + item files preserve tabs) ---
  local fan
  fan="$(DRY_RUN=1 worker::fanout syncitem <<< $'pull\tgithub/acme/widget')"
  t::check "fanout tab round-trip" "ok	github/acme/widget	DRY: would pull" "$fan"

  # --- cli args (safe to mutate globals: selftest exits right after) ---
  cli::parse_args --org acme sync --no-forks --dry-run extra
  t::check "args cmd" "sync" "$CMD"
  t::check "args org" "acme" "$ARG_ORG"
  t::check "args forks" "1" "$EXCLUDE_FORKS"
  t::check "args dry" "1" "$DRY_RUN"
  t::check "args positional" "extra" "${CMD_ARGS[0]:-}"
  DRY_RUN=0 EXCLUDE_FORKS=0

  # --- git helpers on a real fixture repo ---
  if command -v git >/dev/null; then
    local repo="$fix/github/acme/gitfix"
    git init -q -b main "$repo" 2>/dev/null
    ( cd "$repo" && git -c user.email=t@t -c user.name=t -c commit.gpgsign=false \
        commit -q --allow-empty -m init ) || true
    t::check "git current branch" "main" "$(git::current_branch "$repo")"
    t::check "git not empty" "no" "$(git::is_empty "$repo" && echo yes || echo no)"
    t::check "git dirty count clean" "0" "$(git::dirty_count "$repo")"
    t::check "git ahead/behind no upstream" "-	-" "$(git::ahead_behind "$repo")"
    t::check "git has develop (no)" "no" "$(git::has_branch "$repo" develop && echo yes || echo no)"
    git -C "$repo" branch develop
    t::check "git has develop (yes)" "yes" "$(git::has_branch "$repo" develop && echo yes || echo no)"
    t::check "git fetch age never" "never" "$(git::fetch_age "$repo")"
    # status worker row shape (10 TSV fields)
    local row; row="$(worker::do_status "github/acme/gitfix")"
    t::check "status row fields" "10" "$(awk -F'\t' '{print NF}' <<< "$row")"
    t::check "status row label" "ok" "$(cut -f10 <<< "$row")"
  fi

  printf '\n%d passed, %d failed\n' "$T_PASS" "$T_FAIL"
  [ "$T_FAIL" -eq 0 ]
}

#---------------------------------------------------------------- main
main() {
  cli::parse_args "$@"
  cli::dispatch
}

main "$@"
