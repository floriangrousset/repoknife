#!/usr/bin/env bash
#============================================================================
# SECTION 01 — HEADER / META
#----------------------------------------------------------------------------
# repoknife — a git-repos swiss-army-knife TUI
#   sync · pr · runs · health · cleanup · init · config
#   conventions: ~/Code/<provider>/<org>[/<project>]/<repo> · gitflow
#
# NOTE: everything above/inside this guard must stay bash-3.2 parseable so the
# friendly error prints on macOS system bash. bash>=4 syntax lives in functions.
#============================================================================
if [ -z "${BASH_VERSINFO:-}" ] || [ "${BASH_VERSINFO[0]}" -lt 4 ] \
   || { [ "${BASH_VERSINFO[0]}" -eq 4 ] && [ "${BASH_VERSINFO[1]}" -lt 4 ]; }; then
  # >= 4.4: empty-array expansion under `set -u` was only made safe in 4.4
  printf 'repoknife requires bash >= 4.4 (found %s).\n' "${BASH_VERSION:-unknown}" >&2
  printf 'macOS: brew install bash   (system bash 3.2 is unsupported)\n' >&2
  printf 'then re-run: %s\n' "$0" >&2
  exit 1
fi

set -Eeuo pipefail

VERSION="1.8.2"

# --- self-location (resolves symlinks; CODE_ROOT = dir the script lives in) ---
SELF="${BASH_SOURCE[0]}"
while [ -h "$SELF" ]; do
  _dir="$(cd -P "$(dirname "$SELF")" && pwd)"
  SELF="$(readlink "$SELF")"
  case "$SELF" in /*) : ;; *) SELF="$_dir/$SELF" ;; esac
done
SELF="$(cd -P "$(dirname "$SELF")" && pwd)/$(basename "$SELF")"
# CODE_ROOT — the folder holding your github/ · gitlab/ · azure-devops/ trees.
# Resolution order: REPOKNIFE_CODE_ROOT env (pinned) > `code_root` config key
# (applied later in cfg::bootstrap) > walk up from the resolved SELF to the first
# ancestor containing a provider dir > default ~/Code. The walk-up keeps the
# dev symlink convenient; the ~/Code default means a brew binary at
# /opt/homebrew/bin doesn't wrongly anchor itself there.
# (Keep this block bash-3.2 PARSEABLE — it runs above the >=4.4 features.)
if [ -n "${REPOKNIFE_CODE_ROOT:-}" ]; then
  CODE_ROOT="$REPOKNIFE_CODE_ROOT"
  REPOKNIFE_ROOT_PINNED=1
else
  REPOKNIFE_ROOT_PINNED=0
  CODE_ROOT=""
  _probe="$(dirname "$SELF")"
  while [ "$_probe" != "/" ]; do
    if [ -d "$_probe/github" ] || [ -d "$_probe/azure-devops" ] || [ -d "$_probe/gitlab" ]; then
      CODE_ROOT="$_probe"
      break
    fi
    _probe="$(dirname "$_probe")"
  done
  [ -z "$CODE_ROOT" ] && CODE_ROOT="$HOME/Code"
  unset _probe
fi
export REPOKNIFE_SELF="$SELF"

#============================================================================
# SECTION 02 — CONSTANTS & GLOBALS
#============================================================================
# CFG_FILE — script-adjacent config when running from a clone (the committed
# .repoknife.conf is the dev config), else the user-level ~/.repoknife.conf
# (brew / any installed copy). REPOKNIFE_CFG_FILE pins it explicitly.
if [ -n "${REPOKNIFE_CFG_FILE:-}" ]; then
  CFG_FILE="$REPOKNIFE_CFG_FILE"
elif [ -f "$(dirname "$SELF")/.repoknife.conf" ]; then
  CFG_FILE="$(dirname "$SELF")/.repoknife.conf"
else
  CFG_FILE="$HOME/.repoknife.conf"
fi
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/repoknife"
CACHE_TTL="${REPOKNIFE_CACHE_TTL:-3600}"   # seconds
JOBS="${REPOKNIFE_JOBS:-8}"
# a bad REPOKNIFE_JOBS must degrade loudly to the default — not silently break the
# run (non-numeric → xargs errors → swallowed → empty result) or fork-bomb a large
# tree (0 means "as many as possible" to xargs). Reset non-positive-int, clamp high.
[[ "$JOBS" =~ ^[1-9][0-9]*$ ]] || JOBS=8
[ "$JOBS" -gt 64 ] && JOBS=64
OS="$(uname -s)"

PROVIDERS=(github azure-devops gitlab)

# Interactivity is detected ONCE at startup (cli::dispatch) and frozen here.
# Live `[ -t 1 ]` checks are WRONG inside `$(...)` captures — stdout is a pipe
# there even on a real terminal, which is exactly how menus get captured.
INTERACTIVE=0

# mutable run-state flags (set by cli::parse_args). Exported HERE so every
# re-exec child — the hidden _worker/__list/__fanout fast-paths — inherits the
# parent's --plain / --dry-run / fork filter. The export attribute survives the
# later re-assignments in cli::parse_args and cfg bootstrap, so a single export
# at definition is enough (and is the one place that guarantees __list, which
# reads EXCLUDE_FORKS for `gh repo list --source`, sees the right value).
PLAIN="${PLAIN:-0}"
DRY_RUN="${DRY_RUN:-0}"
EXCLUDE_FORKS="${EXCLUDE_FORKS:-0}"
export PLAIN DRY_RUN EXCLUDE_FORKS
USE_EXIT_CODE=0
REFRESH=0
ALL=0
ARG_ORG=""
ARG_PROVIDER=""
CMD=""
CMD_ARGS=()

# per-process temp ROOT — every tmp::dir is created beneath it, so the cleanup
# trap reaps them all with one rm -rf keyed on $$ (deterministic, and identical
# in subshells). This replaces a registry array that was effectively dead:
# tmp::dir is always called via $(...), so any array append happened in the
# command-substitution subshell and was lost — the trap then deleted nothing.
# (partial-clone cleanup is handled IN the worker; git clone removes its own dir on SIGINT)
RK_TMP_ROOT="${TMPDIR:-/tmp}/repoknife.$$"

color::enabled() {
  # fzf preview panes render ANSI but aren't TTYs — parent sets FORCE_COLOR
  [ -n "${REPOKNIFE_FORCE_COLOR:-}" ] && return 0
  [ "$PLAIN" -eq 1 ] && return 1
  [ -n "${NO_COLOR:-}" ] && return 1
  [ ! -t 1 ] && return 1
  [ "${TERM:-}" = "dumb" ] && return 1
  return 0
}

# shellcheck disable=SC2034  # palette is an intentional complete set
palette::init() {
  if color::enabled; then
    C_RED=196 C_RED_DIM=124 C_FG=252 C_DIM=244 C_FAINT=240
    C_GREEN=42 C_YELLOW=214 C_REDX=203 C_BLUE=39 C_PURPLE=141 C_CYAN=51
    # raw ANSI escapes for printf-built lines
    A_RED=$'\e[38;5;196m'; A_DIM=$'\e[38;5;244m'; A_FAINT=$'\e[38;5;240m'
    A_GREEN=$'\e[38;5;42m'; A_YELLOW=$'\e[38;5;214m'; A_REDX=$'\e[38;5;203m'
    A_BLUE=$'\e[38;5;39m'; A_PURPLE=$'\e[38;5;141m'; A_CYAN=$'\e[38;5;51m'
    A_BOLD=$'\e[1m'; A_RST=$'\e[0m'
    G_OK="✓" G_FAIL="✗" G_DIRTY="●" G_CLEAN="○" G_NOTC="◦"
    G_AHEAD="↑" G_BEHIND="↓" G_DIVERGED="⇡⇣" G_WARN="⚠" G_PEND="⠿"
    G_FORK="⑂" G_ARCH="⏸" G_BRAND="🔱" G_RUN="⠋"
  else
    C_RED="" C_RED_DIM="" C_FG="" C_DIM="" C_FAINT=""
    C_GREEN="" C_YELLOW="" C_REDX="" C_BLUE="" C_PURPLE="" C_CYAN=""
    A_RED="" A_DIM="" A_FAINT="" A_GREEN="" A_YELLOW="" A_REDX=""
    A_BLUE="" A_PURPLE="" A_CYAN="" A_BOLD="" A_RST=""
    G_OK="OK" G_FAIL="X" G_DIRTY="*" G_CLEAN="o" G_NOTC="-"
    G_AHEAD="^" G_BEHIND="v" G_DIVERGED="<>" G_WARN="!" G_PEND="."
    G_FORK="[F]" G_ARCH="[A]" G_BRAND="#" G_RUN="~"
  fi
  SPIN_FRAMES=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
}

#============================================================================
# SECTION 03 — LOGGING & ERROR PLUMBING
#============================================================================
log::info() { printf '%s\n' "$*"; }
log::ok()   { printf '%s%s %s%s\n' "$A_GREEN" "$G_OK" "$*" "$A_RST"; }
log::warn() { printf '%s%s %s%s\n' "$A_YELLOW" "$G_WARN" "$*" "$A_RST" >&2; }
log::err()  { printf '%s%s %s%s\n' "$A_REDX" "$G_FAIL" "$*" "$A_RST" >&2; }
log::die()  { log::err "$@"; exit 1; }

cleanup::run() {
  # at-most-once: the INT handler runs this, then re-raises INT which fires the
  # EXIT trap → this again. Guard so it's safe regardless of which trap fires.
  [ -n "${RK_CLEANED:-}" ] && return 0
  RK_CLEANED=1
  rm -rf "$RK_TMP_ROOT" 2>/dev/null || true   # one rm reaps every tmp::dir
  if [ -t 1 ]; then
    printf '\033[?7h\033[?25h' 2>/dev/null || true   # restore autowrap + cursor
    tput cnorm 2>/dev/null || true
  fi
}
trap cleanup::run EXIT
trap 'cleanup::run; trap - INT; kill -INT $$' INT
trap 'cleanup::run' TERM

tmp::dir() {  # mktemp -d beneath RK_TMP_ROOT; cleanup::run reaps the root wholesale
  # no -p, and never adopt a root we don't own: the $$-keyed path is predictable,
  # so a pre-created dir/symlink in a shared /tmp must fail loudly, not be reused
  [ -d "$RK_TMP_ROOT" ] || mkdir -m 700 "$RK_TMP_ROOT" 2>/dev/null || true
  [ -O "$RK_TMP_ROOT" ] || log::die "temp root $RK_TMP_ROOT exists and isn't ours — remove it and retry"
  chmod 700 "$RK_TMP_ROOT"
  mktemp -d "$RK_TMP_ROOT/XXXXXX"
}

#============================================================================
# SECTION 04 — UI HELPERS  (ui::*)
#  All degrade to plain printf when PLAIN or no TTY.
#  Interactive cancels (ESC/ctrl-c in gum/fzf) return rc 130 to the caller.
#============================================================================
ui::is_interactive() { [ "$INTERACTIVE" -eq 1 ]; }

ui::banner() {
  local cols; cols=$(tput cols 2>/dev/null || echo 80)
  if ! ui::is_interactive || [ "$cols" -lt 66 ]; then return 0; fi
  # one atomic printf, no gum/lipgloss: layout engines mis-rendered the art on
  # very wide terminals — plain bytes can't be re-laid-out
  printf '\n%s%s%s\n%s       a git-repos swiss-army-knife · gh · az · gitflow · v%s%s\n%s       crafted by Florian Grousset%s\n\n' \
    "$A_BOLD$A_RED" "$(cat <<'EOF'
  ╔═►   ____  _____ ____   ___  _  ___   _ ___ _____ _____
  ║    |  _ \| ____|  _ \ / _ \| |/ / \ | |_ _|  ___| ____|
  ╠══► | |_) |  _| | |_) | | | | ' /|  \| || || |_  |  _|
  ║    |  _ <| |___|  __/| |_| | . \| |\  || ||  _| | |___
  ╚═►  |_| \_\_____|_|    \___/|_|\_\_| \_|___|_|   |_____|
EOF
)" "$A_RST" "$A_DIM" "$VERSION" "$A_RST" "$A_FAINT" "$A_RST"
}

ui::cols() { tput cols 2>/dev/null || echo 80; }

# Full ANSI/control strip for plain-mode output: OSC (title/clipboard), all CSI
# (not just SGR colors), then residual control bytes. BSD-sed safe via $'' ESC.
# The CSI command uses a ',' delimiter so the intermediate-byte class can be the
# literal range [ -/] (0x20-0x2F): with the '/' delimiter it had to be escaped
# as [ -\/], which brackets parse as space-through-BACKSLASH — that wrongly
# spans digits/uppercase and ate printable text after cursor-movement CSIs.
ui::strip_ansi() {
  LC_ALL=C sed -E $'s/\x1b\\][^\x07\x1b]*(\x07|\x1b\\\\)?//g; s,\x1b\\[[0-9;?]*[ -/]*[@-~],,g' \
    | LC_ALL=C tr -d '\000-\010\013\014\016-\037'
}

# ui::page <Title> <description> [right-context] — consistent banner band atop
# every module screen: rule / title+context / description / rule.
ui::page() {
  ui::is_interactive || return 0
  local title="$1" desc="${2:-}" right="${3:-}"
  local cols w rule
  cols=$(ui::cols); w=$(( cols - 4 )); [ "$w" -gt 110 ] && w=110; [ "$w" -lt 20 ] && w=20
  printf -v rule '─%.0s' $(seq 1 "$w")
  local left="$G_BRAND REPOKNIFE · $title"
  local pad=$(( w - ${#left} - ${#right} ))
  [ "$pad" -lt 1 ] && pad=1
  printf '\n  %s%s%s\n' "$A_FAINT" "$rule" "$A_RST"
  printf '  %s%s%s%*s%s%s%s\n' "$A_BOLD$A_RED" "$left" "$A_RST" "$pad" "" "$A_DIM" "$right" "$A_RST"
  [ -n "$desc" ] && printf '  %s%s%s\n' "$A_DIM" "$desc" "$A_RST"
  printf '  %s%s%s\n' "$A_FAINT" "$rule" "$A_RST"
}

ui::menu() {  # $1=header, rest=options; echoes choice; rc 130 on cancel
  local header="$1"; shift
  if ! ui::is_interactive; then
    log::err "interactive menu unavailable in plain mode — use a subcommand (see --help)"
    return 1
  fi
  local out rc=0
  # left-pad the whole component by 2 so gum's help footer (←↓↑→ navigate …) lands at
  # the same indent as the items; the cursor drops its 2 leading spaces to compensate,
  # so the items stay visually put. (--padding left-only avoids 80-col right-edge wrap.)
  out="$(gum choose --height 14 --padding "0 0 0 2" --cursor "▸ " --cursor.foreground "$C_RED" \
        --header "$header" --header.foreground "$C_DIM" "$@")" || rc=$?
  [ $rc -ne 0 ] && return 130
  printf '%s' "$out"
}

ui::confirm() {  # $1=question [$2=affirmative label] ; rc 0 yes / 1 no or cancel
  local q="$1" aff="${2:-Yes}"
  if ! ui::is_interactive; then return 1; fi
  gum confirm --prompt.foreground "$C_RED" --selected.background "$C_RED" \
    --default=false --affirmative "$aff" --negative "Cancel" "$q"
}

ui::input() {  # $1=prompt [$2=placeholder]
  if ! ui::is_interactive; then return 1; fi
  gum input --prompt "  ❯ " --prompt.foreground "$C_RED" \
    --header "$1" --placeholder "${2:-}"
}

ui::spin() {  # $1=title, rest = command; captures stdout; rc = command rc
  local title="$1"; shift
  if ui::is_interactive; then
    gum spin --spinner dot --spinner.foreground "$C_CYAN" \
      --title "$title" --show-output -- "$@"
  else
    printf '%s\n' "$title" >&2
    "$@"
  fi
}

ui::spin_err() {  # $1=errfile $2=title, rest = command — the COMMAND's stderr
  # goes to the file. NEVER capture ui::spin with 2>&1 instead: gum renders the
  # spinner on ITS stderr, so 2>&1 makes the spinner invisible and mixes its
  # ANSI frames into the captured error text.
  local errf="$1" title="$2"; shift 2
  if ui::is_interactive; then
    # shellcheck disable=SC2016  # $1/$@ deliberately expand in the INNER bash
    gum spin --spinner dot --spinner.foreground "$C_CYAN" \
      --title "$title" --show-output -- \
      bash -c 'exec 2>"$1"; shift; exec "$@"' _ "$errf" "$@"
  else
    printf '%s\n' "$title" >&2
    "$@" 2>"$errf"
  fi
}

ui::pick() {  # fzf wrapper: stdin=lines, "$@"=extra fzf flags; rc 130 on cancel
  local out rc=0
  out="$(fzf --ansi --height=100% --layout=reverse --cycle \
        --pointer='▸' --marker='●' \
        --color="fg:252,fg+:255,bg+:-1,hl:196,hl+:196,marker:196,pointer:196,gutter:-1,border:240" \
        "$@")" || rc=$?
  [ $rc -ne 0 ] && return 130
  printf '%s\n' "$out"
}

ui::box() {  # $1 = border color (gum color code), stdin or $2.. = body lines
  local color="$1"; shift
  if ui::is_interactive; then
    gum style --border rounded --border-foreground "$color" \
      --padding "0 2" --margin "1 0 1 2" "$@"
  else
    printf '%s\n' "$@"
  fi
}

ui::toast() {  # $1 = ok|warn|err, $2.. = message
  local kind="$1"; shift
  case "$kind" in
    ok)   log::ok "$@" ;;
    warn) log::warn "$@" ;;
    *)    log::err "$@" ;;
  esac
  if ui::is_interactive; then sleep 0.7 || true; fi
}

ui::trunc() {  # $1=str $2=maxlen — right-ellipsis
  local s="$1" n="$2"
  if [ "${#s}" -le "$n" ]; then printf '%s' "$s"; else printf '%s…' "${s:0:$((n-1))}"; fi
}

ui::age() {  # $1 = ISO date or epoch → compact age like "2d", "4h", "12m"
  local ts now diff
  if [[ "$1" =~ ^[0-9]+$ ]]; then ts="$1"; else
    if [ "$OS" = "Darwin" ]; then
      ts=$(date -j -u -f '%Y-%m-%dT%H:%M:%SZ' "$1" +%s 2>/dev/null || echo 0)
    else
      ts=$(date -u -d "$1" +%s 2>/dev/null || echo 0)
    fi
  fi
  [ "$ts" -eq 0 ] && { printf '?'; return; }
  now=$(date +%s); diff=$(( now - ts ))
  if   [ $diff -lt 3600 ];   then printf '%dm' $(( diff / 60 ))
  elif [ $diff -lt 86400 ];  then printf '%dh' $(( diff / 3600 ))
  elif [ $diff -lt 2592000 ]; then printf '%dd' $(( diff / 86400 ))
  else printf '%dmo' $(( diff / 2592000 )); fi
}

#============================================================================
# SECTION 05 — CONFIG  (cfg::*)
#  KEY=VALUE file, parsed line-by-line with a strict key allowlist.
#  NEVER sourced (sourcing a config file is arbitrary code execution).
#============================================================================
declare -A CFG=()

cfg::is_allowed_key() {
  case "$1" in
    extra_orgs_github|extra_orgs_gitlab|extra_orgs_azure-devops\
    |ado_default_org|ado_project_map|default_visibility|exclude_forks_default\
    |code_root)
      return 0 ;;
    *) return 1 ;;
  esac
}

cfg::load() {
  CFG=()
  [ -f "$CFG_FILE" ] || return 0
  local line key val
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"   # ltrim
    line="${line%"${line##*[![:space:]]}"}"   # rtrim
    [ -z "$line" ] && continue
    [[ "$line" != *=* ]] && continue
    key="${line%%=*}"; val="${line#*=}"
    key="${key//[[:space:]]/}"
    val="${val#"${val%%[![:space:]]*}"}"; val="${val%"${val##*[![:space:]]}"}"
    cfg::is_allowed_key "$key" || { log::warn "config: ignoring unknown key '$key'"; continue; }
    CFG["$key"]="$val"
  done < "$CFG_FILE"
}

cfg::get() { printf '%s' "${CFG[$1]:-${2:-}}"; }

cfg::set() {  # $1=key $2=value — atomic rewrite preserving other lines
  local key="$1" val="$2"
  cfg::is_allowed_key "$key" || log::die "config: unknown key '$key'"
  local tmp; tmp="$(mktemp "${TMPDIR:-/tmp}/repoknife.conf.XXXXXX")"
  local line written=0
  if [ -f "$CFG_FILE" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
      if [[ "$line" =~ ^[[:space:]]*"$key"[[:space:]]*= ]]; then
        printf '%s=%s\n' "$key" "$val" >> "$tmp"; written=1
      else
        printf '%s\n' "$line" >> "$tmp"
      fi
    done < "$CFG_FILE"
  fi
  [ "$written" -eq 0 ] && printf '%s=%s\n' "$key" "$val" >> "$tmp"
  mv "$tmp" "$CFG_FILE"
  CFG["$key"]="$val"
}

cfg::bootstrap() {  # after cfg::load: honor code_root (env pin wins), export for children
  if [ "${REPOKNIFE_ROOT_PINNED:-0}" -eq 0 ]; then
    local want; want="$(path::expand_tilde "$(cfg::get code_root)")"
    [ -n "$want" ] && CODE_ROOT="$want"
  fi
  export REPOKNIFE_CODE_ROOT="$CODE_ROOT"   # final — workers/spinner children inherit this
}

cfg::firstrun() {  # cold-start: offer to pick/create a code root, or migrate old config
  [ -f "$CFG_FILE" ] && return 0
  # migrate the pre-1.6 location (config used to live at <code-root>/.repoknife.conf)
  local legacy="$HOME/Code/.repoknife.conf"
  if [ -f "$legacy" ] && [ "$legacy" != "$CFG_FILE" ]; then
    if ! ui::is_interactive; then
      log::info "hint: move your config to the new location:  mv $legacy $CFG_FILE"
      return 0
    fi
    if ui::confirm "Found an old config at $legacy — move it to $CFG_FILE?" "Move it"; then
      mv "$legacy" "$CFG_FILE" && { cfg::load; cfg::bootstrap; ui::toast ok "config moved to $CFG_FILE"; }
    fi
    return 0
  fi
  # nothing to migrate — if the resolved root already has provider trees, stay quiet
  { [ -d "$CODE_ROOT/github" ] || [ -d "$CODE_ROOT/gitlab" ] || [ -d "$CODE_ROOT/azure-devops" ]; } && return 0
  if ! ui::is_interactive; then
    log::info "hint: no code root found — set one with 'repoknife config' (key: code_root, default ~/Code)"
    return 0
  fi
  local def="$HOME/Code" pick exp
  pick="$(ui::input "Where do your repos live? (code root)" "$def")" || return 0
  [ -z "$pick" ] && pick="$def"
  exp="$(path::expand_tilde "$pick")"
  ui::confirm "Use $exp as your code root?" "Use it" || return 0
  mkdir -p "$exp" || { ui::toast err "could not create $exp"; return 0; }
  CODE_ROOT="$exp"; export REPOKNIFE_CODE_ROOT="$CODE_ROOT"
  cfg::set code_root "$pick"   # stores the literal value (~ preserved); creates CFG_FILE
  ui::toast ok "code root set: $exp"
}

#============================================================================
# SECTION 06 — PATH / DISCOVERY  (path::* disco::*)
#  arity = path components after ~/Code/<provider>/ that identify one repo
#  github=2 (org/repo) · gitlab=3 (group/project/repo) · azure-devops=3 (org/project/repo)
#  gitlab "project" = subgroup; repos with none live under a literal "No Project" dir
#============================================================================
path::repo_arity() {
  case "$1" in
    github)        echo 2 ;;
    gitlab)        echo 3 ;;
    azure-devops)  echo 3 ;;
    *)             echo 0 ;;
  esac
}

# path::parse <abs-or-rel path under CODE_ROOT> → sets PROVIDER ORG PROJECT REPO
# returns 1 if the path is not a valid repo-leaf path
path::parse() {
  PROVIDER="" ORG="" PROJECT="" REPO=""
  local p="$1"
  p="${p#"$CODE_ROOT"/}"
  p="${p%/}"
  local -a seg
  IFS=/ read -r -a seg <<< "$p"
  PROVIDER="${seg[0]:-}"
  local arity; arity="$(path::repo_arity "$PROVIDER")"
  [ "$arity" -eq 0 ] && return 1
  [ "${#seg[@]}" -ne $(( arity + 1 )) ] && return 1
  ORG="${seg[1]}"
  if [ "$arity" -eq 3 ]; then PROJECT="${seg[2]}"; REPO="${seg[3]}"; else PROJECT=""; REPO="${seg[2]}"; fi
  # reject traversal segments — this parser is the path-safety chokepoint
  local s
  for s in "$ORG" "$PROJECT" "$REPO"; do
    case "$s" in .|..) return 1 ;; esac
  done
  [ -n "$ORG" ] && [ -n "$REPO" ]
}

org::valid() {  # org/account names: alnum . _ - and NOT starting with '-'
  # (a leading '-' would reach `gh repo list "$org"` looking like a flag)
  [[ "$1" =~ ^[A-Za-z0-9._][A-Za-z0-9._-]*$ ]]
}

path::expand_tilde() {  # $1=value; expand a leading ~ / ~/ to $HOME (no eval, no glob)
  local v="$1"
  # shellcheck disable=SC2088  # "~" patterns are literal match targets here, not paths to expand
  case "$v" in
    "~")   printf '%s' "$HOME" ;;
    "~/"*) printf '%s/%s' "$HOME" "${v:2}" ;;   # drop the matched "~/"
    *)     printf '%s' "$v" ;;
  esac
}

disco::providers() {  # providers that exist as folders
  local p
  for p in "${PROVIDERS[@]}"; do
    [ -d "$CODE_ROOT/$p" ] && printf '%s\n' "$p"
  done
  return 0   # the loop's last test may fail — Section 07-style "never errors" contract
}

disco::orgs() {  # $1=provider → union of folder orgs + config extra_orgs_<provider>
  local provider="$1" d extra
  {
    if [ -d "$CODE_ROOT/$provider" ]; then
      for d in "$CODE_ROOT/$provider"/*/; do
        [ -d "$d" ] || continue
        d="$(basename "$d")"
        [[ "$d" == .* ]] && continue
        printf '%s\n' "$d"
      done
    fi
    extra="$(cfg::get "extra_orgs_$provider")"
    if [ -n "$extra" ]; then
      tr ',' '\n' <<< "$extra" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -v '^$' || true
    fi
  } | sort -u
}

disco::ado_projects() {  # $1=org → folder projects + config ado_project_map entries
  local org="$1" d map pair
  {
    if [ -d "$CODE_ROOT/azure-devops/$org" ]; then
      for d in "$CODE_ROOT/azure-devops/$org"/*/; do
        [ -d "$d" ] || continue
        d="$(basename "$d")"
        [[ "$d" == .* ]] && continue
        printf '%s\n' "$d"
      done
    fi
    map="$(cfg::get ado_project_map)"
    if [ -n "$map" ]; then
      # trim each pair like disco::orgs trims extras — the template's documented
      # format is spaced ("corp:Platform, corp:Mobile"); an untrimmed " corp"
      # silently fails the org match and the entry vanishes from the picker
      tr ',' '\n' <<< "$map" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | while IFS= read -r pair; do
        [ "${pair%%:*}" = "$org" ] && printf '%s\n' "${pair#*:}"
      done
    fi
  } | sort -u
}

# disco::ado_projects_live $1=org → ADO projects discovered LIVE via `az`, cached
# (azure-devops-projects namespace, TTL'd, --refresh-busted). ALWAYS rc0 + empty on
# ANY failure (no az / unauthed / network / ESC) so the picker falls back to
# folders+config. The ONLY network path is the ui::spin worker — and it runs in the
# MAIN shell (the picker hoists this into a $() before unioning), never a process
# substitution, and only after ado::ensure_auth already validated auth at mod::sync.
disco::ado_projects_live() {  # $1=org → newline project names (cache-aware)
  local org="$1" out
  [ -n "${REPOKNIFE_NO_DISCOVER:-}" ] && return 0          # hard offline switch (tests / opt-out)
  [ "${REFRESH:-0}" -eq 1 ] && cache::invalidate azure-devops-projects "$org" ""
  if out="$(cache::get azure-devops-projects "$org" "" 2>/dev/null)"; then
    printf '%s\n' "$out"; return 0                          # cache read is safe in any mode
  fi
  ui::is_interactive || return 0                            # skip the NETWORK in plain/CI
  command -v az >/dev/null || return 0
  ado::auth_ok || return 0
  out="$(ui::spin "Discovering ADO projects for ${org}…" "$SELF" __listprojects "$org")" || return 0
  [ -z "$out" ] && return 0                                 # never cache a transient empty
  printf '%s\n' "$out" | cache::put azure-devops-projects "$org" ""
  printf '%s\n' "$out"
}

# disco::ado_orgs_live (no arg) → ADO orgs discovered LIVE via the vssps accounts
# API, cached (azure-devops-orgs/self namespace). Same all-failures-yield-empty
# contract and main-shell/worker discipline as disco::ado_projects_live. Org
# discovery is best-effort — it returns nothing on tenants that block the accounts
# API, in which case the picker uses folders + extra_orgs_azure-devops.
disco::ado_orgs_live() {  # → newline org names (cache-aware)
  local out
  [ -n "${REPOKNIFE_NO_DISCOVER:-}" ] && return 0
  [ "${REFRESH:-0}" -eq 1 ] && cache::invalidate azure-devops-orgs self ""
  if out="$(cache::get azure-devops-orgs self "" 2>/dev/null)"; then
    printf '%s\n' "$out"; return 0
  fi
  ui::is_interactive || return 0
  command -v az >/dev/null || return 0
  ado::auth_ok || return 0
  out="$(ui::spin "Discovering ADO organizations…" "$SELF" __listorgs)" || return 0
  [ -z "$out" ] && return 0
  printf '%s\n' "$out" | cache::put azure-devops-orgs self ""
  printf '%s\n' "$out"
}

# disco::local_repos [provider] → relpaths (provider/org[/project]/repo) of git repos
# at the exact repo-arity depth; never descends into a found repo; skips dotdirs.
disco::local_repos() {
  local want="${1:-}" provider arity
  for provider in "${PROVIDERS[@]}"; do
    [ -n "$want" ] && [ "$provider" != "$want" ] && continue
    [ -d "$CODE_ROOT/$provider" ] || continue
    arity="$(path::repo_arity "$provider")"
    find "$CODE_ROOT/$provider" -mindepth "$arity" -maxdepth "$arity" \
         -name '.*' -prune -o -type d -print 2>/dev/null \
      | while IFS= read -r d; do
          d="${d#"$CODE_ROOT"/}"
          # -mindepth suppresses the -prune above it, so a dotdir at org/project
          # level (github/.backup/x) still descends — filter every component here
          case "$d" in */.*) continue ;; esac
          [ -e "$CODE_ROOT/$d/.git" ] && printf '%s\n' "$d"
        done
  done
  return 0
}

# disco::init_candidates → relpaths of repo-depth dirs that are NOT git repos.
# Only exact repo-arity depth: never ~/Code, provider, or org/project levels.
disco::init_candidates() {
  local provider arity
  for provider in "${PROVIDERS[@]}"; do
    [ -d "$CODE_ROOT/$provider" ] || continue
    arity="$(path::repo_arity "$provider")"
    find "$CODE_ROOT/$provider" -mindepth "$arity" -maxdepth "$arity" \
         -name '.*' -prune -o -type d -print 2>/dev/null \
      | while IFS= read -r d; do
          d="${d#"$CODE_ROOT"/}"
          case "$d" in */.*) continue ;; esac   # see disco::local_repos
          [ -e "$CODE_ROOT/$d/.git" ] || printf '%s\n' "$d"
        done
  done
  return 0
}

#============================================================================
# SECTION 07 — GIT HELPERS  (git::*)
#  Pure-local plumbing. Every helper is detached-HEAD / empty-repo / no-upstream
#  safe and never errors under set -e (callers rely on output, not rc).
#============================================================================
git::is_repo() { [ -e "$1/.git" ]; }

git::current_branch() {  # "HEAD" when detached, "" when not a repo/branchless
  git -C "$1" rev-parse --abbrev-ref HEAD 2>/dev/null || true
}

git::is_empty() {  # no commits at all
  ! git -C "$1" rev-parse --verify -q HEAD >/dev/null 2>&1
}

git::dirty_count() {
  git -C "$1" status --porcelain 2>/dev/null | wc -l | tr -d ' '
}

git::ahead_behind() {  # echoes "ahead<TAB>behind" or "-<TAB>-" (no upstream/detached)
  local dir="$1" branch counts
  branch="$(git::current_branch "$dir")"
  if [ -z "$branch" ] || [ "$branch" = "HEAD" ]; then printf -- '-\t-'; return 0; fi
  if ! counts="$(git -C "$dir" rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null)"; then
    printf -- '-\t-'; return 0
  fi
  # rev-list prints "<behind>\t<ahead>" (left=upstream-only, right=HEAD-only)
  local behind ahead
  behind="${counts%%	*}"; ahead="${counts##*	}"
  printf '%s\t%s' "$ahead" "$behind"
}

git::has_branch() { git -C "$1" show-ref --verify --quiet "refs/heads/$2"; }

# git::branch_rows <dir> → "name<TAB>upstream<TAB>trackclass" per local branch
#  trackclass: gone | ahead/behind text | sync (tracking, in sync) | local (no upstream)
#  GOTCHA: %(upstream:track) is EMPTY both when in-sync and when no upstream —
#  disambiguate via %(upstream:short).
git::branch_rows() {
  git -C "$1" for-each-ref refs/heads \
    --format='%(refname:short)%09%(upstream:short)%09%(upstream:track,nobracket)' 2>/dev/null \
  | while IFS=$'\t' read -r name up track; do
      local class
      if [ "$track" = "gone" ]; then class="gone"
      elif [ -n "$track" ]; then class="$track"
      elif [ -n "$up" ]; then class="sync"
      else class="local"; fi
      printf '%s\t%s\t%s\n' "$name" "$up" "$class"
    done
}

git::gone_count() { git::branch_rows "$1" | awk -F'\t' '$3=="gone"' | wc -l | tr -d ' '; }

git::merged_into() {  # $1=dir $2=branch $3=target → rc 0 if branch merged into target
  git -C "$1" merge-base --is-ancestor "refs/heads/$2" "refs/heads/$3" 2>/dev/null
}

git::fetch_age() {  # compact age since last fetch, "never" if no FETCH_HEAD
  local f="$1/.git/FETCH_HEAD" m
  if [ ! -f "$f" ]; then printf 'never'; return 0; fi
  if [ "$OS" = "Darwin" ]; then m=$(stat -f '%m' "$f" 2>/dev/null || echo 0)
  else m=$(stat -c '%Y' "$f" 2>/dev/null || echo 0); fi
  [ "$m" -eq 0 ] && { printf '?'; return 0; }
  ui::age "$m"
}

#============================================================================
# SECTION 08 — PROVIDER ABSTRACTION
#  provider::dispatch <provider> <verb> [args…] → provider_<p>_<verb>
#  Normalized repo-list TSV (one row per remote repo):
#    name  fork(0/1)  archived(0/1)  empty(0/1)  default_branch  pushed_at  clone_url  description
#============================================================================
provider::dispatch() {
  local provider="$1" verb="$2"; shift 2
  local fn="provider_${provider//-/_}_${verb}"
  if ! declare -F "$fn" >/dev/null; then
    log::err "provider '$provider' does not implement '$verb' (v1 scope)"
    return 1
  fi
  "$fn" "$@"
}

# normalized repo-list jq → 8-col TSV. Held in a constant so the selftest can
# schema-check it (producer/consumer column drift is the classic regression).
JQ_REPO_LIST='.[] | [
      .name,
      (if .isFork then "1" else "0" end),
      (if .isArchived then "1" else "0" end),
      (if .isEmpty then "1" else "0" end),
      (.defaultBranchRef.name // "-"),
      (.pushedAt // "-"),
      (.sshUrl // "-"),
      ((.description // "") | gsub("[[:cntrl:]]"; " "))
    ] | @tsv'
# ---------------------------------------------------------------- github (gh)
provider_github_list_repos() {  # $1=org ; honors EXCLUDE_FORKS
  local org="$1" extra=()
  [ "$EXCLUDE_FORKS" -eq 1 ] && extra+=(--source)
  # default --limit is 30 and silently truncates large accounts — always 1000
  gh repo list "$org" --limit 1000 ${extra[@]+"${extra[@]}"} \
     --json name,isFork,isArchived,isEmpty,defaultBranchRef,pushedAt,sshUrl,description \
  | jq -r "$JQ_REPO_LIST"
}

provider_github_clone_repo() {  # $1=org $2=repo $3=target-dir $4=clone-url(unused)
  # gh repo clone wires the upstream remote automatically for forks.
  # --progress forces git's progress onto stderr even without a tty — the batch
  # renderer tails it into the live status line (% objects, MiB, speed).
  gh repo clone "$1/$2" "$3" -- --progress
}

provider_github_create_repo() {  # $1=org $2=repo $3=local-dir $4=private|public
  local org="$1" repo="$2" dir="$3" vis="$4"
  if gh repo view "$org/$repo" >/dev/null 2>&1; then
    # remote already exists (e.g. an earlier run failed mid-way) — reuse it
    printf 'remote %s/%s already exists — pushing to it\n' "$org" "$repo"
    git -C "$dir" remote get-url origin >/dev/null 2>&1 \
      || git -C "$dir" remote add origin "git@github.com:$org/$repo.git" \
      || { printf 'failed to add origin remote\n'; return 1; }
  else
    ( cd "$dir" && gh repo create "$org/$repo" "--$vis" --source . --remote origin \
        --disable-wiki >/dev/null ) || { printf 'gh repo create failed\n'; return 1; }
  fi
  git -C "$dir" push -q -u origin main        || { printf 'push main failed\n'; return 1; }
  git -C "$dir" push -q -u origin develop     || { printf 'push develop failed\n'; return 1; }
  gh repo edit "$org/$repo" --default-branch develop >/dev/null \
                                              || { printf 'set default=develop failed\n'; return 1; }
}

# ------------------------------------------------------------ azure devops (az)
# normalized discovery jq filters, held in constants so the selftest can run the
# REAL producer on canned JSON (filter/selftest drift is the classic regression).
# Both sanitize remote strings (gsub cntrl) — terminal-injection defense.
JQ_ADO_PROJECTS='.value[]? | (.name // empty) | gsub("[[:cntrl:]]";" ")'
JQ_ADO_ORGS='.value[]? | (.accountName // empty) | gsub("[[:cntrl:]]";" ")'
# Azure DevOps AAD application id — the audience for `az rest` tokens against the
# vssps profile/accounts APIs (org discovery). A fixed, well-known GUID.
ADO_RESOURCE_ID='499b84ac-1321-427f-aa17-267ca6975798'

ado::org_url() { printf 'https://dev.azure.com/%s/' "$1"; }

ado::auth_ok() {  # never run az interactively inside a spinner — pre-check here
  az account show --only-show-errors >/dev/null 2>&1
}

ado::ensure_auth() {  # interactive pre-check — call BEFORE any spinner/capture
  if ! command -v az >/dev/null; then
    fix::offer "Azure DevOps needs the Azure CLI ('az'), which isn't installed." \
               "brew install azure-cli" "command -v az" 2 || return 2
  fi
  ado::auth_ok && return 0
  fix::offer "Azure DevOps isn't authenticated. 'az login' opens an interactive sign-in." \
             "az login" "ado::auth_ok" 2
}

# ADO repo-list jq → same 8-col TSV as JQ_REPO_LIST (constant so the selftest
# schema-checks it; .name sanitized like every other remote-string ingestion)
JQ_ADO_REPO_LIST='.[] | select(.isDisabled != true) | [
      ((.name // "") | gsub("[[:cntrl:]]"; " ")),
      "0", "0",
      (if (.size // 0) == 0 then "1" else "0" end),
      ((.defaultBranch // "-") | sub("^refs/heads/"; "")),
      "-",
      (.sshUrl // "-"),
      ""
    ] | @tsv'

provider_azure_devops_list_repos() {  # $1=org $2=project
  local org="$1" project="$2"
  if ! ado::auth_ok; then
    log::err "Azure DevOps not authenticated. Run: az login   (or az devops login for PAT)"
    return 2
  fi
  az repos list --organization "$(ado::org_url "$org")" --project "$project" \
     --only-show-errors -o json \
  | jq -r "$JQ_ADO_REPO_LIST"
}

provider_azure_devops_clone_repo() {  # $1=org $2=repo $3=target-dir $4=clone-url
  git clone --progress "$4" "$3"
}

provider_azure_devops_list_projects() {  # $1=org → newline project names
  local org="$1"
  ado::auth_ok || { log::err "Azure DevOps not authenticated. Run: az login"; return 2; }
  # AZURE_EXTENSION_USE_DYNAMIC_INSTALL=no: a missing azure-devops extension errors
  # cleanly (→ empty → caller falls back) instead of prompting inside the worker.
  # --top: the API serves ONE page by default — large orgs truncate silently
  AZURE_EXTENSION_USE_DYNAMIC_INSTALL=no \
    az devops project list --organization "$(ado::org_url "$org")" --top 500 --only-show-errors -o json \
  | jq -r "$JQ_ADO_PROJECTS"
}

provider_azure_devops_list_orgs() {  # (no arg) → newline org (accountName) names
  local me
  ado::auth_ok || { log::err "Azure DevOps not authenticated. Run: az login"; return 2; }
  # vssps profile → memberId, then accounts → orgs. Uses the ADO resource token via
  # `az rest` (NOT MS Graph / `az ad signed-in-user`, which is often blocked on
  # guest/restricted tenants). Any empty/failed step → non-zero (caller degrades).
  me="$(az rest --resource "$ADO_RESOURCE_ID" --only-show-errors \
        --url 'https://app.vssps.visualstudio.com/_apis/profile/profiles/me?api-version=7.1' \
        -o json 2>/dev/null | jq -r '.id // empty')"
  [ -n "$me" ] || return 1
  az rest --resource "$ADO_RESOURCE_ID" --only-show-errors \
     --url "https://app.vssps.visualstudio.com/_apis/accounts?memberId=${me}&api-version=7.1" \
     -o json 2>/dev/null \
  | jq -r "$JQ_ADO_ORGS"
}

# ------------------------------------------------------------------ gitlab stub
gitlab::stub() {
  # always rc 1 — there is no glab integration yet, even after a confirmed install
  fix::offer "GitLab support is stubbed in v1 — install glab now to be ready for it." \
             "brew install glab" "command -v glab" 1 || true
  return 1
}
provider_gitlab_list_repos()  { gitlab::stub; }
provider_gitlab_clone_repo()  { gitlab::stub; }
provider_gitlab_create_repo() { gitlab::stub; }

#============================================================================
# SECTION 09 — CACHE  (cache::*)
#  TTL'd remote repo-list TSV per provider+org(+project) under ~/.cache/repoknife.
#  First line: "#fetched_at=<epoch>" — body is the normalized TSV.
#============================================================================
cache::file() {  # $1=provider/namespace $2=org [$3=project] — fork-filter is part of the key
  # sanitize ALL path components: org/project come from config, and the provider
  # reaches here from --provider — none may escape CACHE_DIR ('/', '..')
  local prov="${1//[^A-Za-z0-9._-]/_}" org="${2//[^A-Za-z0-9._-]/_}" project="${3:-}"
  project="${project//[^A-Za-z0-9._-]/_}"
  printf '%s/%s__%s%s%s.tsv' "$CACHE_DIR" "$prov" "$org" "${project:+__$project}" \
    "$( [ "$EXCLUDE_FORKS" -eq 1 ] && printf '__nofork' )"
}

cache::get() {  # → TSV body on stdout; rc 1 on miss/stale; rc 0 fresh
  local f; f="$(cache::file "$@")"
  [ -f "$f" ] || return 1
  local fetched now
  fetched="$(head -1 "$f" | sed -n 's/^#fetched_at=//p')"
  [ -n "$fetched" ] || return 1
  now=$(date +%s)
  [ $(( now - fetched )) -lt "$CACHE_TTL" ] || return 1
  tail -n +2 "$f"
}

cache::put() {  # $1=provider $2=org $3=project-or-"" ; body on stdin
  mkdir -p "$CACHE_DIR" && chmod 700 "$CACHE_DIR"
  local f; f="$(cache::file "$1" "$2" "${3:-}")"
  # $$-suffixed tmp: two concurrent repoknife instances on the same org must
  # not interleave writes into one shared .tmp before the atomic mv
  { printf '#fetched_at=%s\n' "$(date +%s)"; cat; } > "$f.tmp.$$" && mv "$f.tmp.$$" "$f"
}

cache::invalidate() { rm -f "$(cache::file "$@")"; }

#============================================================================
# SECTION 10 — CONCURRENCY WORKER  (worker::*)
#  xargs -P fans out over `$SELF _worker <verb> <outdir> <item>` — each child
#  writes exactly one .out file (TSV result) in a shared mktemp dir; the parent
#  merges after. Workers fast-path in cli::dispatch (no dep/auth/banner cost).
#============================================================================
# Items are passed to workers via numbered files (NOT through xargs -I, which
# mangles tabs/blanks on BSD xargs) — only the index travels on the cmdline.
worker::write_items() {  # $1=outdir ; items on stdin → item.N files; echoes count
  local outdir="$1" i=0 item
  while IFS= read -r item || [ -n "$item" ]; do
    [ -z "$item" ] && continue
    printf '%s' "$item" > "$outdir/item.$i"
    i=$((i+1))
  done
  printf '%s' "$i"
}

worker::fanout() {  # $1=verb ; items on stdin (one per line) ; merged TSV on stdout
  local verb="$1" outdir n
  outdir="$(tmp::dir)"
  n="$(worker::write_items "$outdir")"
  [ "$n" -eq 0 ] && return 0
  export REPOKNIFE_CODE_ROOT="$CODE_ROOT"   # DRY_RUN/EXCLUDE_FORKS exported once at top
  seq 0 $((n-1)) | xargs -P "$JOBS" -I{} "$SELF" _worker "$verb" "$outdir" {} >/dev/null 2>&1 || true
  # reconcile: a worker killed/crashed before its atomic mv leaves no .out — never
  # drop it silently (this tool's whole job is an accurate inventory). Synthesize an
  # error row from the saved item so every requested item is always accounted for.
  local j=0 item
  while [ "$j" -lt "$n" ]; do
    if [ -f "$outdir/$j.out" ]; then
      cat "$outdir/$j.out"
    else
      # fanout items are single-field (relpath / owner-repo); multi-field verbs go
      # through batch::run. tr tabs→spaces so the synthesized row stays exactly 3-col.
      item="$(tr '\t' ' ' < "$outdir/item.$j" 2>/dev/null)"
      printf 'error\t%s\tworker did not complete (killed/crashed)\n' "$item"
    fi
    j=$((j+1))
  done
}

# worker entry — argv: verb outdir index (item read from $outdir/item.$index)
worker::entry() {
  local verb="$1" outdir="$2" idx="$3" item msg
  item="$(cat "$outdir/item.$idx")"
  touch "$outdir/$idx.start"
  if "worker::do_$verb" "$item" > "$outdir/$idx.tmp" 2>"$outdir/$idx.err"; then
    :
  else
    msg="$(tr '\n\t' '  ' < "$outdir/$idx.err" | head -c 160)"   # bytes on BSD and GNU alike (cut -c diverges)
    # a quiet set -e trip can leave .err empty — never emit a reasonless error row
    [ -z "${msg// /}" ] && msg="worker '$verb' exited non-zero (no stderr) — re-run with --plain to see why"
    printf 'error\t%s\t%s\n' "$item" "$msg" > "$outdir/$idx.tmp"
  fi
  mv "$outdir/$idx.tmp" "$outdir/$idx.out"
}

# --- status verb: item = repo relpath → one health TSV row -------------------
# out: relpath branch dirty ahead behind gone dev fetch_age rank state_label
worker::do_status() {
  local rel="$1" dir branch dirty ahead behind gone dev fetch rank label
  dir="$CODE_ROOT/$rel"
  git::is_repo "$dir" || { printf 'error\t%s\tnot a git repo\n' "$rel"; return 0; }
  if git::is_empty "$dir"; then
    # unborn branch: rev-parse lies ("HEAD") — symbolic-ref names it correctly
    branch="$(git -C "$dir" symbolic-ref --short -q HEAD 2>/dev/null || echo '-')"
    printf '%s\t%s\t0\t-\t-\t0\t-\tnever\t7\tEMPTY\n' "$rel" "$branch"
    return 0
  fi
  branch="$(git::current_branch "$dir")"
  dirty="$(git::dirty_count "$dir")"
  IFS=$'\t' read -r ahead behind <<< "$(git::ahead_behind "$dir")"
  gone="$(git::gone_count "$dir")"
  if git::has_branch "$dir" develop; then dev=1; else dev=0; fi
  fetch="$(git::fetch_age "$dir")"
  if [ "$branch" = "HEAD" ]; then branch="detached"; fi
  # worst-first rank: 0 diverged · 1 dirty · 2 no-develop · 3 gone · 4 behind · 5 ahead · 6 clean
  label="ok"; rank=6
  if [ "$ahead" != "-" ] && [ "$ahead" -gt 0 ] 2>/dev/null && [ "$behind" -gt 0 ] 2>/dev/null; then
    rank=0; label="diverged"
  elif [ "$dirty" -gt 0 ]; then rank=1; label="dirty"
  elif [ "$dev" -eq 0 ]; then rank=2; label="no-develop"
  elif [ "$gone" -gt 0 ]; then rank=3; label="gone-br"
  elif [ "$behind" != "-" ] && [ "$behind" -gt 0 ] 2>/dev/null; then rank=4; label="behind"
  elif [ "$ahead" != "-" ] && [ "$ahead" -gt 0 ] 2>/dev/null; then rank=5; label="unpushed"
  fi
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$rel" "$branch" "$dirty" "$ahead" "$behind" "$gone" "$dev" "$fetch" "$rank" "$label"
}

# --- syncstate verb: item = cloned repo relpath → "rel<TAB>dirty<TAB>ahead<TAB>behind"
# parallel local-state for the Sync table — sync::browse used to compute this
# serially in the main shell (~3 git spawns per cloned repo). Only cloned repos
# are passed in; join the result back by repo name.
worker::do_syncstate() {
  local rel="$1" dir ab dirty ahead behind
  dir="$CODE_ROOT/$rel"
  dirty="$(git::dirty_count "$dir")"
  ab="$(git::ahead_behind "$dir")"
  ahead="${ab%%	*}"; behind="${ab##*	}"
  printf '%s\t%s\t%s\t%s\n' "$rel" "$dirty" "$ahead" "$behind"
}

# --- pull verb: item = repo relpath → "ok|skip|error <rel> <message>" --------
worker::do_pull() {
  local rel="$1" dir before after n
  dir="$CODE_ROOT/$rel"
  if [ "$DRY_RUN" -eq 1 ]; then printf 'ok\t%s\tDRY: would pull\n' "$rel"; return 0; fi
  if [ "$(git::dirty_count "$dir")" -gt 0 ]; then
    printf 'skip\t%s\tdirty working tree\n' "$rel"; return 0
  fi
  before="$(git -C "$dir" rev-parse HEAD 2>/dev/null || echo none)"
  if ! git -C "$dir" pull --ff-only -q 2>/dev/null; then
    printf 'error\t%s\tpull failed (diverged or no upstream) — resolve manually\n' "$rel"
    return 0
  fi
  after="$(git -C "$dir" rev-parse HEAD 2>/dev/null || echo none)"
  if [ "$before" = "$after" ]; then printf 'ok\t%s\talready up to date\n' "$rel"
  else
    n="$(git -C "$dir" rev-list --count "$before..$after" 2>/dev/null || echo '?')"
    printf 'ok\t%s\tpulled %s commit(s)\n' "$rel" "$n"
  fi
}

# --- clone verb: item = "relpath<TAB>clone_url<TAB>default_branch" ------------
worker::do_clone() {
  local rel url defbranch dir
  IFS=$'\t' read -r rel url defbranch <<< "$1"
  dir="$CODE_ROOT/$rel"
  if [ "$DRY_RUN" -eq 1 ]; then printf 'ok\t%s\tDRY: would clone\n' "$rel"; return 0; fi
  if [ -d "$dir" ]; then printf 'skip\t%s\ttarget dir already exists\n' "$rel"; return 0; fi
  path::parse "$rel" || { printf 'error\t%s\tbad path\n' "$rel"; return 0; }
  # scheme allowlist: the clone URL is server-provided — never let it select a
  # git transport like ext:: (command execution) or a local path
  case "$url" in
    https://*|ssh://*|git@*) : ;;
    *) printf 'error\t%s\tclone url has unexpected scheme: %s\n' "$rel" "${url:0:60}"; return 0 ;;
  esac
  mkdir -p "$(dirname "$dir")"
  # stderr intentionally NOT discarded: it flows to the worker's .err file,
  # where batch::render picks up git's live clone progress
  if ! provider::dispatch "$PROVIDER" clone_repo "$ORG" "$REPO" "$dir" "$url" >/dev/null; then
    rm -rf "$dir"   # never leave a half-clone (dir created by us this run)
    printf 'error\t%s\tclone failed\n' "$rel"; return 0
  fi
  # gitflow nicety: land on develop when the remote has one
  if git -C "$dir" show-ref --verify --quiet refs/remotes/origin/develop; then
    git -C "$dir" checkout -q develop 2>/dev/null || true
  fi
  printf 'ok\t%s\tcloned%s\n' "$rel" "$( [ "$defbranch" != "-" ] && printf ' (default %s)' "$defbranch" )"
}

# --- runs verb: item = "owner/repo" → recent workflow-run rows ----------------
# out per run: id  owner/repo  glyphclass  workflow  branch  age  title
# normalized runs jq → 7-col TSV (schema-checked in selftest). $r is a jq
# variable supplied via --arg, hence the single-quote SC2016 disable.
# shellcheck disable=SC2016
JQ_RUNS='.[] | [
      (.databaseId | tostring), $r,
      (if .status != "completed" then (if .status == "queued" then "queued" else "running" end)
       elif .conclusion == "success" then "pass"
       elif .conclusion == "skipped" then "skipped"
       else "fail" end),
      ((.workflowName // "") | gsub("[[:cntrl:]]"; " ") | if . == "" then "-" else . end),
      ((.headBranch // "") | gsub("[[:cntrl:]]"; " ") | if . == "" then "-" else . end),
      .createdAt,
      ((.displayTitle // "") | gsub("[[:cntrl:]]"; " "))
    ] | @tsv'
worker::do_runs() {
  local nwo="$1"
  # gh failures must propagate (no 2>/dev/null, no || true): worker::entry then
  # synthesizes the error row from gh's real stderr — that row is what makes the
  # auth/rate-limit hint in mod::runs reachable at all
  gh run list -R "$nwo" --limit 5 \
     --json databaseId,status,conclusion,displayTitle,workflowName,headBranch,createdAt \
  | jq -r --arg r "$nwo" "$JQ_RUNS"
}

# --- syncitem verb: item = "clone<TAB>…" or "pull<TAB>rel" -------------------
worker::do_syncitem() {
  local action rest
  action="${1%%	*}"; rest="${1#*	}"
  case "$action" in
    clone) worker::do_clone "$rest" ;;
    pull)  worker::do_pull  "$rest" ;;
    *)     printf 'error\t%s\tunknown sync action\n' "$rest" ;;
  esac
}

#============================================================================
# SECTION 11 — MODULES  (mod::*)
#============================================================================

# ---------------------------------------------------------------- batch runner
# items in BATCH_ITEMS[]; live multi-line renderer (interactive) or sequential
# plain output. Results merged into BATCH_RESULTS[] ("status<TAB>rel<TAB>msg").
BATCH_ITEMS=()
BATCH_RESULTS=()
# renderer caches (reset per batch::run): one label per item, state/msg ingested
# once per finished item, completion order for the height-limited window
BATCH_LABELS=(); BATCH_STATE=(); BATCH_MSG=(); BATCH_DONE_ORDER=()
BATCH_OKC=0; BATCH_SKIPC=0; BATCH_FAILC=0

batch::label() {  # $1=item [$2=maxw] — pure bash, no forks; verbs strip to the relpath basename
  local f="${1%%	*}" w="${2:-0}"
  if [ "$f" = clone ] || [ "$f" = pull ]; then f="${1#*	}"; f="${f%%	*}"; fi
  f="${f##*/}"
  if [ "$w" -gt 0 ] && [ "${#f}" -gt "$w" ]; then f="${f:0:$((w-1))}…"; fi
  printf '%s' "$f"
}

batch::winmath() {  # $1=maxlines $2=inflight $3=done → "show_inflight show_done"
  # one line of the budget is reserved for the summary footer
  local max="$1" inf="$2" dn="$3" cap wi wd
  cap=$(( max - 1 )); [ "$cap" -lt 1 ] && cap=1
  wi="$inf"; [ "$wi" -gt "$cap" ] && wi="$cap"
  wd=$(( cap - wi )); [ "$wd" -gt "$dn" ] && wd="$dn"
  printf '%s %s' "$wi" "$wd"
}

batch::run() {  # $1 = worker verb
  local verb="$1" outdir n=${#BATCH_ITEMS[@]}
  BATCH_RESULTS=()
  [ "$n" -eq 0 ] && return 0
  # renderer state: labels precomputed ONCE (the renderer used to fork
  # label/trunc/printf subshells per item per 250ms frame — O(N) forks/frame);
  # finished items are ingested once into state/msg caches, never re-read.
  BATCH_LABELS=(); BATCH_STATE=(); BATCH_MSG=(); BATCH_DONE_ORDER=()
  BATCH_OKC=0; BATCH_SKIPC=0; BATCH_FAILC=0; BATCH_LASTN=0
  local it
  for it in "${BATCH_ITEMS[@]}"; do
    BATCH_LABELS+=("$(batch::label "$it" 24)")
  done
  outdir="$(tmp::dir)"
  export REPOKNIFE_CODE_ROOT="$CODE_ROOT"   # DRY_RUN/EXCLUDE_FORKS exported once at top
  printf '%s\n' "${BATCH_ITEMS[@]}" | worker::write_items "$outdir" >/dev/null
  seq 0 $((n-1)) \
    | xargs -P "$JOBS" -I{} "$SELF" _worker "$verb" "$outdir" {} >/dev/null 2>&1 &
  local xpid=$!
  if ui::is_interactive; then
    # hide cursor + disable autowrap: a wrapped status line breaks the cursor-up math
    printf '\033[?25l\033[?7l' || true
    local first=1
    while :; do
      batch::render "$outdir" "$first"; first=0
      kill -0 "$xpid" 2>/dev/null || break
      sleep 0.25
    done
    wait "$xpid" 2>/dev/null || true
    batch::render "$outdir" 0
    printf '\033[?7h\033[?25h' || true
  else
    wait "$xpid" 2>/dev/null || true
  fi
  # reconcile: an item whose worker was killed before its atomic mv leaves no .out —
  # synthesize a failure row so batch::summary accounts for EVERY item (a
  # "Sync complete · 0 failed" box must never silently omit an interrupted clone/pull).
  local j=0 f irel
  while [ "$j" -lt "$n" ]; do
    f="$outdir/$j.out"
    if [ -f "$f" ]; then
      BATCH_RESULTS+=("$(cat "$f")")
    else
      irel="${BATCH_ITEMS[$j]#*$'\t'}"; irel="${irel%%$'\t'*}"   # field 2 = relpath
      BATCH_RESULTS+=("error"$'\t'"$irel"$'\t'"interrupted — no result (re-run; check for a partial clone)")
    fi
    j=$((j+1))
  done
}

SPIN_I=0
BATCH_LASTN=0
batch::render() {  # $1=outdir $2=first(1|0)
  local outdir="$1" first="$2" idx line state msg prog progw lbl
  local cols rows maxlines
  cols=$(ui::cols); rows=$(tput lines 2>/dev/null || echo 24)
  progw=$(( cols - 34 )); [ "$progw" -lt 24 ] && progw=24; [ "$progw" -gt 90 ] && progw=90
  maxlines=$(( rows - 4 )); [ "$maxlines" -lt 5 ] && maxlines=5
  SPIN_I=$(( (SPIN_I + 1) % ${#SPIN_FRAMES[@]} ))

  # ingest newly finished items ONCE (cache state+msg, record completion order)
  local n=${#BATCH_ITEMS[@]} inflight=()
  for idx in "${!BATCH_ITEMS[@]}"; do
    [ -n "${BATCH_STATE[$idx]:-}" ] && continue
    if [ -f "$outdir/$idx.out" ]; then
      IFS=$'\t' read -r state _ msg < "$outdir/$idx.out"
      BATCH_STATE[idx]="$state"; BATCH_MSG[idx]="$msg"
      BATCH_DONE_ORDER+=("$idx")
      case "$state" in
        ok)   BATCH_OKC=$((BATCH_OKC+1)) ;;
        skip) BATCH_SKIPC=$((BATCH_SKIPC+1)) ;;
        *)    BATCH_FAILC=$((BATCH_FAILC+1)) ;;
      esac
    elif [ -f "$outdir/$idx.start" ]; then
      inflight+=("$idx")
    fi
  done

  # pick the lines for this frame: everything when it fits, else a window of
  # live items + the most recent completions, with one summary footer line
  # (cursor-up by the FULL item count on an over-tall batch scroll-spammed the
  # terminal at 4 fps — CUU clamps at the top row, every frame re-scrolled)
  local dn=${#BATCH_DONE_ORDER[@]}
  local queued=$(( n - dn - ${#inflight[@]} ))
  local show=() footer=""
  if [ "$n" -le "$maxlines" ]; then
    show=("${!BATCH_ITEMS[@]}")
  else
    local wi wd
    read -r wi wd <<< "$(batch::winmath "$maxlines" "${#inflight[@]}" "$dn")"
    [ "$wi" -gt 0 ] && show+=("${inflight[@]:0:$wi}")
    [ "$wd" -gt 0 ] && show+=("${BATCH_DONE_ORDER[@]: -$wd}")
    footer="  ${A_DIM}… ${dn} done (${BATCH_OKC} ok · ${BATCH_SKIPC} skipped · ${BATCH_FAILC} failed) · ${#inflight[@]} running · ${queued} queued — of ${n}${A_RST}"
  fi

  [ "$first" -eq 0 ] && [ "$BATCH_LASTN" -gt 0 ] && printf '\033[%dA' "$BATCH_LASTN"
  local printed=0
  for idx in ${show[@]+"${show[@]}"}; do
    printf -v lbl '%-24s' "${BATCH_LABELS[$idx]}"
    state="${BATCH_STATE[$idx]:-}"
    if [ -n "$state" ]; then
      msg="${BATCH_MSG[$idx]}"
      case "$state" in
        ok)    line="${A_GREEN}${G_OK}${A_RST} ${lbl} ${A_DIM}${msg}${A_RST}" ;;
        skip)  line="${A_YELLOW}${G_WARN}${A_RST} ${lbl} ${A_YELLOW}skipped${A_RST} ${A_DIM}· ${msg}${A_RST}" ;;
        *)     line="${A_REDX}${G_FAIL}${A_RST} ${lbl} ${A_REDX}${msg}${A_RST}" ;;
      esac
    elif [ -f "$outdir/$idx.start" ]; then
      # live progress: git clone --progress streams to the worker's .err —
      # show the freshest line (CR-separated updates, so split on \r too)
      prog=""
      if [ -s "$outdir/$idx.err" ]; then
        prog="$(tail -c 512 "$outdir/$idx.err" 2>/dev/null | tr '\r' '\n' \
                | grep -v '^[[:space:]]*$' | tail -1 | LC_ALL=C tr -d '\000-\037' || true)"
      fi
      if [ -z "$prog" ]; then
        case "${BATCH_ITEMS[$idx]}" in clone*) prog="cloning…" ;; pull*) prog="pulling…" ;; *) prog="working…" ;; esac
      fi
      line="${A_CYAN}${SPIN_FRAMES[$SPIN_I]}${A_RST} ${lbl} ${A_DIM}$(ui::trunc "$prog" "$progw")${A_RST}"
    else
      line="${A_FAINT}${G_PEND}${A_RST} ${lbl} ${A_FAINT}queued${A_RST}"
    fi
    printf '\033[2K  %s\n' "$line"
    printed=$((printed+1))
  done
  if [ -n "$footer" ]; then printf '\033[2K%s\n' "$footer"; printed=$((printed+1)); fi
  printf '\033[J'   # erase leftovers when this frame printed fewer lines than the last
  BATCH_LASTN="$printed"
}

batch::summary() {  # $1 = title ; prints semantic-colored box from BATCH_RESULTS
  local title="$1" ok=0 skip=0 fail=0 r state rel msg
  local skipped=() failed=()
  for r in ${BATCH_RESULTS[@]+"${BATCH_RESULTS[@]}"}; do
    IFS=$'\t' read -r state rel msg <<< "$r"
    case "$state" in
      ok)   ok=$((ok+1)) ;;
      skip) skip=$((skip+1)); skipped+=("  $G_WARN $(basename "$rel") · $msg") ;;
      *)    fail=$((fail+1)); failed+=("  $G_FAIL $(basename "$rel") · $msg") ;;
    esac
  done
  local color="$C_GREEN"
  [ "$skip" -gt 0 ] && color="$C_YELLOW"
  [ "$fail" -gt 0 ] && color="$C_REDX"
  local body="$title
$G_OK $ok done · $G_WARN $skip skipped · $G_FAIL $fail failed"
  if [ "${#skipped[@]}" -gt 0 ]; then
    body="$body

Skipped (left untouched):
$(printf '%s\n' "${skipped[@]}")"
  fi
  if [ "${#failed[@]}" -gt 0 ]; then
    body="$body

Failed:
$(printf '%s\n' "${failed[@]}")"
  fi
  ui::box "$color" "$body"
}

# ----------------------------------------------------------------- pickers
# Pickers set SEL (+ SEL_WAS_MENU=1 when an actual menu was shown) instead of
# echoing — they must run in the MAIN shell so navigation can know whether ESC
# has a previous menu to return to. rc 130 = user cancelled.
SEL=""
SEL_WAS_MENU=0

mod::pick_provider() {  # [$1=org hint] → SEL; honors --provider
  SEL="" SEL_WAS_MENU=0
  if [ -n "$ARG_PROVIDER" ]; then SEL="$ARG_PROVIDER"; return 0; fi
  local org="${1:-}" p
  # infer from the org when it belongs to exactly one provider (folder or config)
  if [ -n "$org" ]; then
    local matches=()
    for p in "${PROVIDERS[@]}"; do
      disco::orgs "$p" | grep -qxF "$org" && matches+=("$p")
    done
    if [ "${#matches[@]}" -eq 1 ]; then SEL="${matches[0]}"; return 0; fi
  fi
  local provs=()
  while IFS= read -r p; do provs+=("$p"); done < <(disco::providers)
  [ "${#provs[@]}" -eq 0 ] && provs=(github)
  if [ "${#provs[@]}" -eq 1 ]; then SEL="${provs[0]}"; return 0; fi
  if ! ui::is_interactive; then SEL="github"; return 0; fi   # sensible plain default
  SEL_WAS_MENU=1
  SEL="$(ui::menu "pick provider" "${provs[@]}")"
}

mod::pick_org() {  # $1=provider → SEL ; fzf picker with type-to-search
  SEL="" SEL_WAS_MENU=0
  local provider="$1"
  if [ -n "$ARG_ORG" ]; then SEL="$ARG_ORG"; return 0; fi
  local orgs=() o live=""
  # azure-devops: union LIVE org discovery (vssps accounts API, cached) with the
  # offline source (folders + extra_orgs_azure-devops). The spinner-bearing live
  # fetch is hoisted into a $() in the MAIN shell; the proc-sub only merges text.
  [ "$provider" = "azure-devops" ] && live="$(disco::ado_orgs_live)"
  while IFS= read -r o; do [ -n "$o" ] && orgs+=("$o"); done \
       < <( { printf '%s\n' "$live"; disco::orgs "$provider"; } | sort -u )
  [ "${#orgs[@]}" -eq 0 ] && { log::err "no orgs found for $provider (add folders or config extra_orgs_$provider)"; return 1; }
  if [ "${#orgs[@]}" -eq 1 ]; then SEL="${orgs[0]}"; return 0; fi
  if ! ui::is_interactive; then log::err "multiple orgs — pass one with --org"; return 1; fi
  # enrich each org with its local clone count (one disco call, counted in-shell)
  local locals rows=() r n
  locals="$(disco::local_repos "$provider")"
  for o in "${orgs[@]}"; do
    n=0
    while IFS= read -r r; do case "$r" in "$provider/$o"/*) n=$((n+1)) ;; esac; done <<< "$locals"
    if [ "$n" -gt 0 ]; then
      rows+=("$o	$(printf '%-32s' "$(ui::trunc "$o" 32)") ${A_DIM}● $n local${A_RST}")
    else
      rows+=("$o	$(printf '%-32s' "$(ui::trunc "$o" 32)") ${A_FAINT}◦ no local clones${A_RST}")
    fi
  done
  SEL_WAS_MENU=1
  SEL="$(printf '%s\n' "${rows[@]}" | ui::pick \
        --delimiter='\t' --with-nth=2 \
        --header="pick org ($provider) · type to search · enter select · esc back" \
        | cut -f1)"
}

mod::pick_ado_project() {  # $1=org → SEL ; fzf picker with type-to-search
  SEL="" SEL_WAS_MENU=0
  local org="$1" projects=() p live offline
  # union LIVE discovery (az devops project list, cached) with the offline source
  # (folders + ado_project_map). The spinner-bearing live fetch is hoisted into a
  # $() in the MAIN shell — NEVER inside the process substitution (gum spin in a
  # proc-sub corrupts the TTY); the proc-sub below only merges plain text.
  live="$(disco::ado_projects_live "$org")"
  offline="$(disco::ado_projects "$org")"
  # live empty in an interactive, authed session means discovery FAILED — not "no
  # projects". Warn so the user isn't silently dropped into the one locally-known
  # project (the classic "I only see Orchestra" trap) with no idea discovery broke.
  if [ -z "$live" ] && [ -z "${REPOKNIFE_NO_DISCOVER:-}" ] && ui::is_interactive \
     && command -v az >/dev/null && ado::auth_ok; then
    log::warn "live ADO project discovery returned nothing for '$org' — showing only locally-known projects (check the 'azure-devops' az extension · az login · network; --refresh to retry)"
  fi
  while IFS= read -r p; do [ -n "$p" ] && projects+=("$p"); done \
       < <(printf '%s\n%s\n' "$live" "$offline" | sort -u)
  [ "${#projects[@]}" -eq 0 ] && { log::err "no ADO project found for '$org' — check 'az login' / the org name, or set ado_project_map=$org:<project>"; return 1; }
  if [ "${#projects[@]}" -eq 1 ]; then SEL="${projects[0]}"; return 0; fi
  if ! ui::is_interactive; then log::err "multiple ADO projects for '$org' — set config ado_project_map"; return 1; fi
  local locals rows=() r n
  locals="$(disco::local_repos azure-devops)"
  for p in "${projects[@]}"; do
    n=0
    while IFS= read -r r; do case "$r" in "azure-devops/$org/$p"/*) n=$((n+1)) ;; esac; done <<< "$locals"
    if [ "$n" -gt 0 ]; then
      rows+=("$p	$(printf '%-32s' "$(ui::trunc "$p" 32)") ${A_DIM}● $n local${A_RST}")
    else
      rows+=("$p	$(printf '%-32s' "$(ui::trunc "$p" 32)") ${A_FAINT}◦ no local clones${A_RST}")
    fi
  done
  SEL_WAS_MENU=1
  SEL="$(printf '%s\n' "${rows[@]}" | ui::pick \
        --delimiter='\t' --with-nth=2 \
        --header="pick ADO project ($org) · type to search · enter select · esc back" \
        | cut -f1)"
}

# pops the navigation stack (caller's NAV/STEP locals, bash dynamic scoping);
# rc 1 when there is no previous menu — caller exits to its own parent.
nav::pop() {
  [ "${#NAV[@]}" -gt 0 ] || return 1
  local i=$(( ${#NAV[@]} - 1 ))
  STEP="${NAV[$i]}"
  unset "NAV[$i]"
}

# ------------------------------------------------------------------- mod::sync
# Navigation state machine: provider → org → project (ADO) → repo list.
# ESC goes back exactly ONE level — to the previous step that actually showed
# a menu (auto-skipped steps don't trap the user) — and exits only from the top.
mod::sync() {
  local arg_org="${1:-$ARG_ORG}" provider="" org="" project=""
  local STEP="provider" NAV=()
  while :; do
    case "$STEP" in
      provider)
        mod::pick_provider "$arg_org" || return 0
        provider="$SEL"
        if [ "$provider" = "gitlab" ]; then gitlab::stub || true; return 0; fi
        [ "$provider" = "github" ] && { auth::check_gh || return 2; }
        [ "$provider" = "azure-devops" ] && { ado::ensure_auth || return 2; }
        [ "$SEL_WAS_MENU" -eq 1 ] && NAV+=(provider)
        STEP=org ;;
      org)
        # azure-devops: an unset org falls back to the configured default (if any)
        [ -z "$arg_org" ] && [ "$provider" = azure-devops ] && arg_org="$(cfg::get ado_default_org)"
        if [ -n "$arg_org" ]; then org="$arg_org"
        else
          if ! mod::pick_org "$provider"; then nav::pop && continue; return 0; fi
          org="$SEL"
          [ "$SEL_WAS_MENU" -eq 1 ] && NAV+=(org)
        fi
        org::valid "$org" || { log::err "invalid org name: $org"; return 1; }
        STEP=project ;;
      project)
        project=""
        if [ "$provider" = "azure-devops" ]; then
          if ! mod::pick_ado_project "$org"; then nav::pop && continue; return 0; fi
          project="$SEL"
          [ "$SEL_WAS_MENU" -eq 1 ] && NAV+=(project)
        fi
        STEP=list ;;
      list)
        local rc=0
        sync::browse "$provider" "$org" "$project" || rc=$?
        if [ "$rc" -eq 130 ]; then nav::pop && continue; return 0; fi
        return "$rc" ;;
    esac
  done
}

sync::browse() {  # $1=provider $2=org $3=project — fetch, table, select, execute
  local provider="$1" org="$2" project="$3"

  # ---- fetch remote list (cache-aware) ----
  local tsv
  if [ "$REFRESH" -eq 1 ]; then cache::invalidate "$provider" "$org" "$project"; fi
  if ! tsv="$(cache::get "$provider" "$org" "$project" 2>/dev/null)"; then
    tsv="$(ui::spin "Fetching $org repos ($provider)…" \
            "$SELF" __list "$provider" "$org" "$project")" || {
      log::err "failed to fetch repo list for $org"; return 1; }
    printf '%s\n' "$tsv" | cache::put "$provider" "$org" "$project"
  fi
  [ -z "$tsv" ] && { log::warn "no repos found for $org"; return 0; }

  # ---- cross-reference local state (fanned out, like health) ----
  local tmptsv; tmptsv="$(tmp::dir)/sync.tsv"
  printf '%s\n' "$tsv" > "$tmptsv"

  # collect already-cloned repos under this provider/org[/project] ONCE (one disco
  # walk feeds both the state fanout and orphan detection), then compute their
  # dirty/ahead/behind in PARALLEL via the worker pool. sync::browse used to do ~3
  # serial git spawns per cloned repo in the main shell — slow on large orgs.
  local pfx lrel
  if [ -n "$project" ]; then pfx="$provider/$org/$project"; else pfx="$provider/$org"; fi
  declare -A ST_DIRTY=() ST_AHEAD=() ST_BEHIND=() ST_CLONED=()
  local cloned=()
  while IFS= read -r lrel; do
    [ -z "$lrel" ] && continue
    case "$lrel" in "$pfx"/*) cloned+=("$lrel"); ST_CLONED["${lrel##*/}"]=1 ;; esac
  done < <(disco::local_repos "$provider")
  if [ "${#cloned[@]}" -gt 0 ]; then
    local strows srel sdirty sahead sbehind snm
    strows="$(printf '%s\n' "${cloned[@]}" | ui::spin "Checking ${#cloned[@]} local clone(s)…" "$SELF" __fanout syncstate)"
    while IFS=$'\t' read -r srel sdirty sahead sbehind; do
      [ -z "$srel" ] && continue
      [ "$srel" = "error" ] && continue
      snm="${srel##*/}"
      ST_DIRTY["$snm"]="$sdirty"; ST_AHEAD["$snm"]="$sahead"; ST_BEHIND["$snm"]="$sbehind"
    done <<< "$strows"
  fi

  local cols namew
  cols=$(ui::cols)
  namew=$(( cols >= 160 ? 50 : cols >= 120 ? 40 : 30 ))
  local lines=() name fork arch empty defbranch pushed url desc
  local state ahead behind badges disp
  declare -A remote_set=()
  while IFS=$'\t' read -r name fork arch empty defbranch pushed url desc; do
    [ -z "$name" ] && continue
    remote_set["$name"]=1
    badges=""
    [ "$fork" = "1" ] && badges="$badges ${A_PURPLE}[FORK]${A_RST}"
    [ "$arch" = "1" ] && badges="$badges ${A_PURPLE}[ARCH]${A_RST}"
    [ "$empty" = "1" ] && badges="$badges ${A_FAINT}[EMPTY]${A_RST}"
    if [ -n "${ST_CLONED[$name]:-}" ]; then
      if [ "${ST_DIRTY[$name]:-0}" -gt 0 ] 2>/dev/null; then
        state="${A_YELLOW}${G_DIRTY}${A_RST}"; badges="$badges ${A_YELLOW}[DIRTY]${A_RST}"
      else
        state="${A_DIM}${G_CLEAN}${A_RST}"
      fi
      ahead="${ST_AHEAD[$name]:--}"; behind="${ST_BEHIND[$name]:--}"
      [ "$behind" != "-" ] && [ "$behind" != "0" ] && badges="$badges ${A_YELLOW}[${G_BEHIND}${behind}]${A_RST}"
      [ "$ahead"  != "-" ] && [ "$ahead"  != "0" ] && badges="$badges ${A_BLUE}[${G_AHEAD}${ahead}]${A_RST}"
    else
      state="${A_FAINT}${G_NOTC}${A_RST}"; badges="$badges ${A_GREEN}[NEW]${A_RST}"
    fi
    disp="$state $(printf "%-${namew}s" "$(ui::trunc "$name" "$namew")")$badges ${A_DIM}$(ui::age "$pushed")${A_RST}"
    lines+=("$name"$'\t'"$disp")
  done <<< "$tsv"

  # orphaned: cloned dirs absent from the remote list (renamed/deleted upstream).
  # O(1) membership via remote_set; reuse the already-collected `cloned` (no 2nd walk).
  local lname
  for lrel in ${cloned[@]+"${cloned[@]}"}; do
    lname="${lrel##*/}"
    [ -n "${remote_set[$lname]:-}" ] && continue
    lines+=("!$lname"$'\t'"${A_REDX}${G_WARN}${A_RST} $(printf "%-${namew}s" "$lname")${A_REDX}[ORPHANED]${A_RST} ${A_DIM}local only — remote renamed/deleted?${A_RST}")
  done

  # ---- plain / non-interactive path ----
  if ! ui::is_interactive; then
    printf '%s\n' "${lines[@]}" | cut -f2- | ui::strip_ansi
    if [ "$DRY_RUN" -eq 1 ] || [ "$ALL" -eq 1 ]; then
      mod::sync_execute "$provider" "$org" "$project" "$tmptsv" __ALL__
    else
      log::info ""
      log::info "hint: re-run interactively, or add --all (clone+pull everything) / --dry-run"
    fi
    return 0
  fi

  # ---- interactive multi-select ----
  ui::page "Sync" "multi-select repos, then batch clone (missing) / pull (cloned) — dirty repos are skipped, never touched" \
    "$provider/$org${project:+/$project} · ${#lines[@]} repos"
  export REPOKNIFE_TSV="$tmptsv" REPOKNIFE_CTX="$provider $org $project" REPOKNIFE_FORCE_COLOR=1
  local sel qself; printf -v qself '%q' "$SELF"
  sel="$(printf '%s\n' "${lines[@]}" | ui::pick --multi \
        --delimiter='\t' --with-nth=2 \
        --header="type to search · space/tab select · ctrl-a all · ctrl-d none · enter run · esc back" \
        --bind 'space:toggle+down,ctrl-a:select-all,ctrl-d:deselect-all' \
        --preview "$qself __preview sync {1}" \
        --preview-window='right,45%,border-left,wrap' \
        | cut -f1)" || { unset REPOKNIFE_FORCE_COLOR; return 130; }   # ESC → one level up
  unset REPOKNIFE_FORCE_COLOR
  [ -z "$sel" ] && return 130
  mod::sync_execute "$provider" "$org" "$project" "$tmptsv" "$sel"
}

mod::sync_execute() {  # $1=provider $2=org $3=project $4=tsvfile $5=selection|__ALL__
  local provider="$1" org="$2" project="$3" tmptsv="$4" sel="$5"
  local name fork arch empty defbranch pushed url desc rel dir
  # selection membership via one assoc map — a grep fork per TSV row stalled
  # multi-second on 1000-repo orgs before anything rendered
  declare -A want=()
  local w
  if [ "$sel" != "__ALL__" ]; then
    while IFS= read -r w; do [ -n "$w" ] && want["$w"]=1; done <<< "$sel"
  fi
  BATCH_ITEMS=()
  while IFS=$'\t' read -r name fork arch empty defbranch pushed url desc; do
    [ -z "$name" ] && continue
    if [ "$sel" != "__ALL__" ]; then
      [ -n "${want[$name]:-}" ] || continue
    fi
    [ "$empty" = "1" ] && continue   # nothing to clone/pull on an empty repo
    if [ -n "$project" ]; then rel="$provider/$org/$project/$name"; else rel="$provider/$org/$name"; fi
    dir="$CODE_ROOT/$rel"
    if git::is_repo "$dir"; then
      BATCH_ITEMS+=("pull	$rel")
    else
      BATCH_ITEMS+=("clone	$rel	$url	$defbranch")
    fi
  done < "$tmptsv"
  local k
  while IFS= read -r k; do
    case "$k" in '!'*) log::warn "orphaned repos can't be synced — inspect them manually"; break ;; esac
  done <<< "$sel"
  [ "${#BATCH_ITEMS[@]}" -eq 0 ] && { log::info "nothing to do"; return 0; }
  ui::page "Sync · $org" "running batch — ${G_PEND} queued · ${G_OK} done · ${G_WARN} skipped · ${G_FAIL} failed" \
    "${#BATCH_ITEMS[@]} repo(s)"
  batch::run syncitem
  batch::summary "Sync complete · $org"
}

# ------------------------------------------------------------------- mod::init
INIT_ERR=""
init::local_one() {  # $1=relpath → 0 ok / 1 fail (INIT_ERR set). main+develop, develop checked out.
  local rel="$1" dir="$CODE_ROOT/$1" err
  INIT_ERR=""
  # every step is checked — a silent half-init is worse than a loud failure
  if ! err="$(git init -q -b main "$dir" 2>&1)"; then
    INIT_ERR="git init: $err"; return 1
  fi
  if ! err="$(git -C "$dir" add -A 2>&1)"; then
    INIT_ERR="git add: $err"; init::rollback "$dir"; return 1
  fi
  # nothing staged (empty dir, only empty subdirs, or everything gitignored) → seed a README
  if git -C "$dir" diff --cached --quiet 2>/dev/null; then
    printf '# %s\n' "$(basename "$rel")" > "$dir/README.md"
    git -C "$dir" add -f README.md 2>/dev/null || true
  fi
  if ! err="$(git -C "$dir" commit -q -m 'chore: initial commit' 2>&1)"; then
    INIT_ERR="commit: $(head -1 <<< "$err")"
    case "$err" in
      *"Couldn't load public key"*|*gpg*|*sign*)
        INIT_ERR="$INIT_ERR — commit SIGNING is failing machine-wide. Check: git config user.signingkey + gpg.format (macOS: ssh-add --apple-load-keychain)" ;;
    esac
    init::rollback "$dir"; return 1
  fi
  if ! git -C "$dir" rev-parse --verify -q main >/dev/null 2>&1; then
    INIT_ERR="main branch missing after commit"; init::rollback "$dir"; return 1
  fi
  if ! err="$(git -C "$dir" branch develop 2>&1)"; then
    INIT_ERR="branch develop: $err"; init::rollback "$dir"; return 1
  fi
  if ! err="$(git -C "$dir" checkout -q develop 2>&1)"; then
    INIT_ERR="checkout develop: $err"; init::rollback "$dir"; return 1
  fi
  return 0
}

init::rollback() {  # remove the .git WE just created so the folder stays a clean candidate
  rm -rf "${1:?}/.git"
}

mod::init() {
  local cands=() c scan
  # spinner hoisted into a main-shell $() (gotcha #14: gum spin inside a process
  # substitution corrupts the TTY) — and a failed scan must error loudly, not
  # read as "tree is clean" (the proc-sub form swallowed the child's rc)
  scan="$(ui::spin "Scanning $CODE_ROOT for non-git folders…" "$SELF" __initscan)" \
    || { log::err "init scan failed — re-run with --plain to see why"; return 1; }
  while IFS= read -r c; do [ -n "$c" ] && cands+=("$c"); done <<< "$scan"
  if [ "${#cands[@]}" -eq 0 ]; then log::ok "no non-git folders found — tree is clean"; return 0; fi

  if ! ui::is_interactive; then
    printf '%s\n' "${cands[@]}"
    [ "$DRY_RUN" -eq 1 ] && log::info "DRY: would offer git init -b main + develop on each"
    return 0
  fi

  ui::page "Init" "turn plain folders into gitflow repos: init main → commit → develop (default) · then optional GitHub remote" \
    "${#cands[@]} candidate(s)"
  export REPOKNIFE_FORCE_COLOR=1
  local sel qself; printf -v qself '%q' "$SELF"
  sel="$(printf '%s\n' "${cands[@]}" | ui::pick --multi \
        --bind 'space:toggle+down,ctrl-a:select-all,ctrl-d:deselect-all' \
        --header="type to search · space/tab select · ctrl-a all · enter continue · esc back" \
        --preview "$qself __preview init {}" \
        --preview-window='right,45%,border-left,wrap')" || { unset REPOKNIFE_FORCE_COLOR; return 0; }
  unset REPOKNIFE_FORCE_COLOR
  [ -z "$sel" ] && return 0

  local rel dir vis choice remote_jobs=() results=()
  local default_vis; default_vis="$(cfg::get default_visibility private)"
  # read the selection on fd 3, NOT fd 0: the per-folder gum menu below inherits
  # stdin, and gum drains a non-TTY fd 0 even with args — with `done <<< "$sel"`
  # only the FIRST selected folder would survive the loop (rest eaten by gum)
  while IFS= read -r rel <&3; do
    [ -z "$rel" ] && continue
    dir="$CODE_ROOT/$rel"
    path::parse "$rel" || { log::err "$rel: cannot parse path"; continue; }
    if [ "$DRY_RUN" -eq 1 ]; then
      results+=("$G_OK $rel · DRY: would init main+develop")
      continue
    fi
    # --- local init: main → commit → develop (develop checked out, gitflow) ---
    if ! init::local_one "$rel"; then
      log::err "$rel → init FAILED: $INIT_ERR"
      results+=("$G_FAIL $rel · init failed (rolled back — fix the cause and re-run)")
      continue
    fi
    log::ok "$rel → local init done (main + develop, develop checked out)"
    # --- offer remote (github only in v1) ---
    if [ "$PROVIDER" = "github" ]; then
      local opts=("Yes, create private" "Yes, create public" "No, local only")
      [ "$default_vis" = "public" ] && opts=("Yes, create public" "Yes, create private" "No, local only")
      choice="$(ui::menu "Create GitHub remote $ORG/$REPO?" "${opts[@]}")" || choice="No, local only"
      case "$choice" in
        *private*) remote_jobs+=("$rel	private") ;;
        *public*)  remote_jobs+=("$rel	public") ;;
        *)         results+=("$G_OK $rel · local only") ;;
      esac
    else
      results+=("$G_OK $rel · local only (remote creation not supported for $PROVIDER in v1)")
    fi
  done 3<<< "$sel"

  # --- batch confirm + create remotes ---
  if [ "${#remote_jobs[@]}" -gt 0 ]; then
    local job
    log::info ""
    log::warn "about to create ${#remote_jobs[@]} remote repo(s) on GitHub:"
    for job in "${remote_jobs[@]}"; do
      IFS=$'\t' read -r rel vis <<< "$job"
      path::parse "$rel" || continue
      log::info "    $ORG/$REPO ($vis)"
    done
    if ui::confirm "Create ${#remote_jobs[@]} remote repo(s) on GitHub?" "Create"; then
      auth::check_gh || return 2
      local out errf emsg; errf="$(tmp::dir)/createremote.err"
      for job in "${remote_jobs[@]}"; do
        IFS=$'\t' read -r rel vis <<< "$job"
        path::parse "$rel" || continue
        if out="$(ui::spin_err "$errf" "Creating $ORG/$REPO ($vis)…" \
             "$SELF" __createremote "$ORG" "$REPO" "$CODE_ROOT/$rel" "$vis")"; then
          results+=("$G_OK $rel · remote created · pushed · default=develop")
        else
          # diagnosis: gh/git stderr if any, else the worker's own stdout reason
          emsg="$(tail -1 "$errf" 2>/dev/null || true)"
          [ -z "$emsg" ] && emsg="$(tail -1 <<< "$out")"
          results+=("$G_FAIL $rel · remote: $emsg")
        fi
      done
    else
      for job in "${remote_jobs[@]}"; do
        results+=("$G_WARN ${job%%	*} · remote creation cancelled (local init kept)")
      done
    fi
  fi
  [ "${#results[@]}" -gt 0 ] && ui::box "$C_GREEN" "Init complete
$(printf '%s\n' "${results[@]}")"
}

# --------------------------------------------------------------------- mod::pr
PR_JSON_FIELDS="number,title,repository,isDraft,updatedAt,author"

# normalized PR-list jq → 3-col TSV (number · nameWithOwner · display row), a
# JQ_* constant so the selftest schema-checks it like its siblings. $tw is a jq
# variable supplied via --argjson, hence the single-quote SC2016 disable.
# shellcheck disable=SC2016
JQ_PR_LIST='.[] | [
      (.number|tostring),
      ((.repository.nameWithOwner // "") | gsub("[[:cntrl:]]"; " ")),
      ((if .isDraft then "○ " else "● " end) + (.repository.name // "?") + " #" + (.number|tostring)
        + "  " + (((.title // "") | gsub("[[:cntrl:]]"; " "))[:$tw])
        + "  @" + ((.author.login // "?") | gsub("[[:cntrl:]]"; " ")))
    ] | @tsv'

pr::fetch() {  # $1 = scope: all|mine|review|assigned|mentions → JSON array on stdout
  local a b
  case "$1" in
    mine)     gh search prs --author=@me           --state=open --limit 100 --sort updated --json "$PR_JSON_FIELDS" ;;
    review)   gh search prs --review-requested=@me --state=open --limit 100 --sort updated --json "$PR_JSON_FIELDS" ;;
    assigned) gh search prs --assignee=@me         --state=open --limit 100 --sort updated --json "$PR_JSON_FIELDS" ;;
    mentions) gh search prs --mentions=@me         --state=open --limit 100 --sort updated --json "$PR_JSON_FIELDS" ;;
    all)
      # involves: author+assignee+mentions+commenter — review-requested is NOT included, merge it
      # --sort updated like the sibling scopes: past the 100-result truncation,
      # search-relevance order would keep arbitrary matches over recent ones
      a="$(gh search prs --involves=@me --state=open --limit 100 --sort updated --json "$PR_JSON_FIELDS")" || a="[]"
      b="$(gh search prs --review-requested=@me --state=open --limit 100 --sort updated --json "$PR_JSON_FIELDS")" || b="[]"
      jq -s '.[0] + .[1] | unique_by(.repository.nameWithOwner + "#" + (.number|tostring))
             | sort_by(.updatedAt) | reverse' <<< "$a
$b" ;;
    *) printf '[]' ;;
  esac
}

pr::scope_label() {
  case "$1" in
    mine) printf 'authored by me' ;;     review)   printf 'review requested' ;;
    assigned) printf 'assigned to me' ;; mentions) printf 'mentioning me' ;;
    *) printf 'all involving me' ;;
  esac
}

mod::pr() {
  auth::check_gh || return 2
  local scope="${1:-}"
  case "$scope" in ""|all|mine|review|assigned|mentions) : ;; *) log::die "unknown PR scope: $scope (all·mine·review·assigned·mentions)" ;; esac
  while :; do
    # ---- scope menu ----
    if [ -z "$scope" ]; then
      if ! ui::is_interactive; then scope="all"
      else
        ui::page "Pull Requests" "pick which PRs to show — esc here goes back to the main menu" ""
        local choice
        choice="$(ui::menu "PR scope" \
          "🌐  All involving me    authored + assigned + mentioned + review-requested" \
          "📝  Authored by me" \
          "👀  Review requested" \
          "🎯  Assigned to me" \
          "💬  Mentioning me" \
          "←   Back")" || return 0
        case "$choice" in
          *Authored*)  scope="mine" ;;
          *Review*)    scope="review" ;;
          *Assigned*)  scope="assigned" ;;
          *Mentioning*) scope="mentions" ;;
          *All*)       scope="all" ;;
          *) return 0 ;;
        esac
      fi
    fi
    # ---- fetch ----
    local json
    json="$(ui::spin "Fetching PRs ($(pr::scope_label "$scope"))…" "$SELF" __prfetch "$scope")" || json="[]"
    local count; count="$(jq 'length' <<< "$json" 2>/dev/null || echo 0)"
    if [ "$count" -eq 0 ]; then
      ui::toast warn "no open PRs ($(pr::scope_label "$scope"))"
      if ui::is_interactive; then scope=""; continue; else return 0; fi
    fi

    local lines=() titlew
    titlew=$(( $(ui::cols) >= 160 ? 90 : $(ui::cols) >= 120 ? 64 : 48 ))
    while IFS= read -r row; do lines+=("$row"); done < <(jq -r --argjson tw "$titlew" "$JQ_PR_LIST" <<< "$json")

    if ! ui::is_interactive; then
      printf '%s\n' "${lines[@]}" | awk -F'\t' '{print $2 " #" $1 "\t" $3}'
      return 0
    fi

    ui::page "Pull Requests" "open PRs across ALL orgs · preview = live gh pr view · esc returns to the scope menu" \
      "$(pr::scope_label "$scope") · $count open"
    local sel num nwo
    sel="$(printf '%s\n' "${lines[@]}" | ui::pick \
          --delimiter='\t' --with-nth=3 \
          --header="type to search · enter actions (checkout · diff · approve · merge · browser) · esc scope menu" \
          --preview "gh pr view {1} --repo {2}" \
          --preview-window='right,45%,border-left,wrap')" || { scope=""; continue; }
    [ -z "$sel" ] && { scope=""; continue; }
    num="$(cut -f1 <<< "$sel")"; nwo="$(cut -f2 <<< "$sel")"
    mod::pr_actions "$num" "$nwo" || true
  done
}

mod::pr_actions() {  # $1=number $2=owner/repo
  local num="$1" nwo="$2"
  local meta base head
  meta="$(ui::spin "Loading PR #${num}…" gh pr view "$num" -R "$nwo" \
          --json baseRefName,headRefName,title 2>/dev/null)" || meta="{}"
  base="$(jq -r '.baseRefName // "?"' <<< "$meta")"
  head="$(jq -r '.headRefName // "?"' <<< "$meta")"
  local strategy="--squash" stratlabel="squash"
  if [ "$base" = "main" ] || [ "$base" = "master" ]; then strategy="--merge"; stratlabel="merge commit"; fi
  # NEVER delete long-lived branches: a develop→main PR must not nuke develop
  local del="--delete-branch" delmsg=" and delete $head"
  case "$head" in develop|main|master) del="" delmsg="" ;; esac

  while :; do
    local act
    ui::page "Pull Request" "merge strategy follows gitflow: squash → develop · merge commit → main" "$nwo #$num · $head → $base"
    act="$(ui::menu "$nwo #$num · $head → $base" \
          "⤓  Checkout branch" "🔍  View diff" "$G_OK  Approve" \
          "⇋  Merge ($stratlabel → $base)" "🌐  Open in browser" "←  Back")" || return 0
    case "$act" in
      *Checkout*)
        local owner repo dir
        owner="${nwo%%/*}"; repo="${nwo##*/}"
        dir="$CODE_ROOT/github/$owner/$repo"
        if ! git::is_repo "$dir"; then
          if ui::confirm "$repo is not cloned locally — clone it now?" "Clone"; then
            mkdir -p "$(dirname "$dir")"
            ui::spin "Cloning ${nwo}…" gh repo clone "$nwo" "$dir" || { ui::toast err "clone failed"; continue; }
          else continue; fi
        fi
        # gh pr checkout writes to the CURRENT repo — must cd into the clone
        if ( cd "$dir" && gh pr checkout "$num" ); then
          ui::toast ok "checked out $head in $dir"
        else ui::toast err "checkout failed"; fi
        ;;
      *diff*)   ( gh pr diff "$num" -R "$nwo" --color always | less -R ) || true ;;
      *Approve*)
        local aerrf; aerrf="$(tmp::dir)/gh.err"
        if ui::spin_err "$aerrf" "Approving #${num}…" gh pr review "$num" -R "$nwo" --approve >/dev/null; then
          ui::toast ok "approved #$num"
        else fix::offer_gh_postmortem "$(cat "$aerrf" 2>/dev/null || true)" "approve failed"; fi
        ;;
      *Merge*)
        if ui::confirm "$stratlabel #$num into $base$delmsg?" "Merge"; then
          local merrf; merrf="$(tmp::dir)/gh.err"
          if ui::spin_err "$merrf" "Merging #${num}…" gh pr merge "$num" -R "$nwo" "$strategy" ${del:+"$del"} >/dev/null; then
            ui::toast ok "merged #$num into $base"; return 0
          else fix::offer_gh_postmortem "$(cat "$merrf" 2>/dev/null || true)" "merge failed (checks pending / not mergeable?)"; fi
        fi
        ;;
      *browser*) gh pr view "$num" -R "$nwo" --web >/dev/null 2>&1 || true ;;
      *) return 0 ;;
    esac
  done
}

# ------------------------------------------------------------------- mod::runs
mod::runs() {
  auth::check_gh || return 2
  local org repos=() rel
  org="${1:-$ARG_ORG}"
  if [ -z "$org" ]; then mod::pick_org github || return 0; org="$SEL"; fi
  while IFS= read -r rel; do
    case "$rel" in github/"$org"/*) repos+=("github/$org $rel") ;; esac
  done < <(disco::local_repos github)
  local nwos=()
  for rel in ${repos[@]+"${repos[@]}"}; do
    nwos+=("$org/$(basename "${rel##* }")")
  done
  [ "${#nwos[@]}" -eq 0 ] && { log::warn "no local repos for github/$org — clone some first (sync)"; return 0; }

  local rows
  rows="$(printf '%s\n' "${nwos[@]}" | ui::spin "Fetching runs across ${#nwos[@]} repos…" \
          "$SELF" __fanout runs)" || rows=""
  [ -z "$rows" ] && { log::warn "no workflow runs found"; return 0; }

  # per-repo workers can't prompt — surface one auth hint if error rows look auth-related
  if grep -q '^error	' <<< "$rows" && grep -qiE 'auth|not logged|HTTP 401' <<< "$rows"; then
    log::warn "some repos failed with auth errors — try: gh auth login"
  fi

  # sort newest first by createdAt (field 6), cap at 40
  # (grep -v exits 1 when it filters EVERYTHING — must not abort under pipefail)
  rows="$(LC_ALL=C sort -t$'\t' -k6,6r <<< "$rows" | grep -v '^error	' | head -40 || true)"

  local cols repow wfw brw
  cols=$(ui::cols)
  repow=$(( cols >= 160 ? 28 : 16 )); wfw=$(( cols >= 160 ? 36 : cols >= 120 ? 28 : 22 )); brw=$(( cols >= 120 ? 22 : 14 ))
  local lines=() id nwo class wf branch created title glyph
  while IFS=$'\t' read -r id nwo class wf branch created title; do
    [ -z "$id" ] && continue
    case "$class" in
      pass)    glyph="${A_GREEN}${G_OK}${A_RST}" ;;
      fail)    glyph="${A_REDX}${G_FAIL}${A_RST}" ;;
      running) glyph="${A_CYAN}${G_RUN}${A_RST}" ;;
      queued)  glyph="${A_FAINT}${G_PEND}${A_RST}" ;;
      *)       glyph="${A_DIM}${G_CLEAN}${A_RST}" ;;
    esac
    lines+=("$id	$nwo	$glyph $(printf "%-${repow}s" "$(ui::trunc "${nwo##*/}" "$repow")") $(printf "%-${wfw}s" "$(ui::trunc "$wf" "$wfw")") ${A_BLUE}$(printf "%-${brw}s" "$(ui::trunc "$branch" "$brw")")${A_RST} ${A_DIM}$(ui::age "$created")${A_RST}")
  done <<< "$rows"

  if ! ui::is_interactive; then
    printf '%s\n' "${lines[@]}" | cut -f3- | ui::strip_ansi
    return 0
  fi

  while :; do
    ui::page "Actions" "recent workflow runs across local repos of the org · preview = job breakdown" \
      "github/$org · ${#lines[@]} recent"
    local sel
    sel="$(printf '%s\n' "${lines[@]}" | ui::pick \
          --delimiter='\t' --with-nth=3 \
          --header="type to search · enter actions (watch · rerun failed · logs · browser) · esc back" \
          --preview "gh run view {1} --repo {2}" \
          --preview-window='right,45%,border-left,wrap')" || return 0
    [ -z "$sel" ] && return 0
    mod::runs_actions "$(cut -f1 <<< "$sel")" "$(cut -f2 <<< "$sel")" || true
  done
}

mod::runs_actions() {  # $1=run id $2=owner/repo
  local id="$1" nwo="$2"
  while :; do
    local act
    ui::page "Actions · run" "rerun-failed requires the 'workflow' token scope (gh auth refresh -s workflow)" "$nwo · run $id"
    act="$(ui::menu "🤖 $nwo · run $id" \
          "👁  Watch live" "↻  Re-run failed jobs" "📄  View failure logs" \
          "🌐  Open in browser" "←  Back")" || return 0
    case "$act" in
      *Watch*)   gh run watch "$id" -R "$nwo" || true ;;   # live stream — never capture/spin
      *Re-run*)
        if ! auth::has_workflow_scope; then
          fix::offer "Re-running failed jobs needs the 'workflow' token scope, which your gh token lacks." \
                     "gh auth refresh -s workflow" "auth::has_workflow_scope" || continue
        fi
        if ui::spin "Re-running failed jobs…" gh run rerun "$id" -R "$nwo" --failed; then
          ui::toast ok "re-run requested"
        else ui::toast err "re-run failed"; fi
        ;;
      *logs*)
        local rlog
        if rlog="$(gh run view "$id" -R "$nwo" --log-failed 2>&1)"; then
          printf '%s\n' "$rlog" | less -R
        else fix::offer_gh_postmortem "$rlog" "could not load failure logs"; fi
        ;;
      *browser*) gh run view "$id" -R "$nwo" --web >/dev/null 2>&1 || true ;;
      *) return 0 ;;
    esac
  done
}

# ----------------------------------------------------------------- mod::health
mod::health() {
  local repos=() rel
  while IFS= read -r rel; do [ -n "$rel" ] && repos+=("$rel"); done < <(disco::local_repos)
  [ "${#repos[@]}" -eq 0 ] && { log::warn "no local repos found under $CODE_ROOT"; return 0; }

  local discovered=${#repos[@]} rows
  # guarded like its mod::runs sibling: as a CLI subcommand errexit is live, and
  # an unguarded assignment would die silently INSTEAD of reaching the explicit
  # fan-out-failure diagnostic below (which honors --exit-code for CI)
  rows="$(printf '%s\n' "${repos[@]}" | ui::spin "Scanning ${discovered} repos…" "$SELF" __fanout status)" || rows=""
  rows="$(LC_ALL=C sort -t$'\t' -k9,9n -k1,1 <<< "$rows")"   # C locale: byte-deterministic, BSD/GNU-identical, broken-locale-safe
  # a totally empty result for a non-empty tree is a fan-out FAILURE, not "all clean"
  if [ -z "${rows//[[:space:]]/}" ]; then
    log::err "health scan produced no results for $discovered repo(s) — worker fan-out failed"
    if [ "$USE_EXIT_CODE" -eq 1 ] && ! ui::is_interactive; then exit 255; fi
    return 1
  fi

  # counts (errored = repos that could not be scanned — folded into attention so a
  # broken scan can never read as a clean tree)
  local dirty=0 unpushed=0 behind=0 nodev=0 gone=0 attention=0 total=0 errored=0
  local r branch d a b g dev fetch rank label
  while IFS=$'\t' read -r rel branch d a b g dev fetch rank label; do
    [ -z "$rel" ] && continue
    if [ "$rel" = "error" ]; then errored=$((errored+1)); attention=$((attention+1)); continue; fi
    total=$((total+1))
    [ "$d" -gt 0 ] 2>/dev/null && dirty=$((dirty+1))
    [ "$a" != "-" ] && [ "$a" -gt 0 ] 2>/dev/null && unpushed=$((unpushed+1))
    [ "$b" != "-" ] && [ "$b" -gt 0 ] 2>/dev/null && behind=$((behind+1))
    [ "$dev" = "0" ] && nodev=$((nodev+1))
    [ "$g" -gt 0 ] 2>/dev/null && gone=$((gone+1))
    [ "$rank" -lt 6 ] 2>/dev/null && attention=$((attention+1))
  done <<< "$rows"

  # persist counts for the instant main-menu header (tmp+mv like cache::put —
  # a concurrent menu::counts must never read a partially-written file)
  mkdir -p "$CACHE_DIR" && chmod 700 "$CACHE_DIR"
  printf '{"at":%s,"repos":%s,"scanned":%s,"dirty":%s,"behind":%s,"attention":%s,"errored":%s}\n' \
    "$(date +%s)" "$discovered" "$total" "$dirty" "$behind" "$attention" "$errored" \
    > "$CACHE_DIR/counts.json.tmp.$$" && mv "$CACHE_DIR/counts.json.tmp.$$" "$CACHE_DIR/counts.json"

  # display lines (column widths scale with the terminal)
  local cols repow brw
  cols=$(ui::cols)
  repow=$(( cols >= 160 ? 56 : cols >= 120 ? 44 : 34 )); brw=$(( cols >= 120 ? 16 : 10 ))
  local lines=() prov rest disp pcol
  while IFS=$'\t' read -r rel branch d a b g dev fetch rank label; do
    [ -z "$rel" ] && continue
    if [ "$rel" = "error" ]; then
      # error row: $branch holds the failed relpath, $d holds the message
      lines+=("$branch"$'\t'"${A_REDX}$(printf '%-3s' '!!')$(printf "%-${repow}s" "$(ui::trunc "$branch" "$repow")")${A_RST} ${A_REDX}scan failed: $(ui::trunc "$d" 40)${A_RST}")
      continue
    fi
    prov="${rel%%/*}"; rest="${rel#*/}"
    case "$prov" in github) prov=gh ;; azure-devops) prov=az ;; gitlab) prov=gl ;; esac
    local stxt scol pad
    case "$label" in
      diverged)   stxt="$G_DIVERGED diverged"; scol="$A_REDX" ;;
      dirty)      stxt="$G_DIRTY dirty ($d)";  scol="$A_YELLOW" ;;
      no-develop) stxt="$G_FAIL no develop";   scol="$A_REDX" ;;
      gone-br)    stxt="⌫ $g gone";            scol="$A_REDX" ;;
      behind)     stxt="$G_BEHIND$b behind";   scol="$A_YELLOW" ;;
      unpushed)   stxt="$G_AHEAD$a unpushed";  scol="$A_BLUE" ;;
      EMPTY)      stxt="empty";                scol="$A_FAINT" ;;
      *)          stxt="$G_OK ok";             scol="$A_GREEN" ;;
    esac
    # pad on CHAR length (UTF-8 aware), color applied around the padded text —
    # printf '%-Ns' on a string carrying ANSI pads on bytes and misaligns columns
    pad=$(( 14 - ${#stxt} )); [ "$pad" -lt 0 ] && pad=0
    disp="${scol}${stxt}${A_RST}$(printf '%*s' "$pad" '')"
    [ "$dev" = "1" ] && pcol="${A_GREEN}${G_OK}${A_RST}" || pcol="${A_REDX}${G_FAIL}${A_RST}"
    [ "$dev" = "-" ] && pcol="${A_FAINT}-${A_RST}"
    lines+=("$rel	$(printf '%-3s' "$prov")$(printf "%-${repow}s" "$(ui::trunc "$rest" "$repow")") ${A_BLUE}$(printf "%-${brw}s" "$(ui::trunc "$branch" "$brw")")${A_RST} $disp dev:$pcol ${A_FAINT}fetch:$fetch${A_RST}")
  done <<< "$rows"

  local summary="💚 Health · $discovered repos · $G_WARN $attention need attention
$G_DIRTY $dirty dirty · $G_AHEAD $unpushed unpushed · $G_BEHIND $behind behind · $G_FAIL $nodev no-develop · ⌫ $gone gone-branches"
  [ "$errored" -gt 0 ] && summary="$summary · $G_WARN $errored unscannable"

  if ! ui::is_interactive; then
    printf '%s\n' "${lines[@]}" | cut -f2- | ui::strip_ansi
    printf '\n%s repos need attention (of %s)' "$attention" "$discovered"
    [ "$errored" -gt 0 ] && printf ' · %s unscannable' "$errored"
    printf '\n'
    if [ "$USE_EXIT_CODE" -eq 1 ]; then
      # errored repos are folded into attention, so a broken scan can't read as exit 0
      # exit codes wrap mod 256 — clamp so 256+ attention repos never read as success
      [ "$attention" -gt 254 ] && exit 254
      exit "$attention"
    fi
    return 0
  fi

  ui::page "Health" "every local repo, worst-first · enter a repo to inspect & fix (lazygit · fetch · pull · create develop · cleanup)" \
    "$discovered repos · $G_WARN $attention attention"
  ui::box "$( [ "$attention" -eq 0 ] && echo "$C_GREEN" || echo "$C_YELLOW" )" "$summary"
  # NOTE: fzf auto-quotes {1} — it must stand alone, NEVER inside quotes
  local qroot colhdr
  printf -v qroot '%q' "$CODE_ROOT"
  colhdr="$(printf '%-3s%-*s %-*s %-13s %s' '' "$repow" 'REPO' "$brw" 'BRANCH' 'STATE' 'DEV    FETCH')"
  while :; do
    local sel
    sel="$(printf '%s\n' "${lines[@]}" | ui::pick \
          --delimiter='\t' --with-nth=2 \
          --header="type to search (try: dirty) · enter inspect · esc back
$colhdr" \
          --preview "git -C $qroot/{1} -c color.status=always status -sb; echo; git -C $qroot/{1} log --oneline -8 --color=always" \
          --preview-window='right,45%,border-left')" || return 0
    [ -z "$sel" ] && return 0
    mod::health_actions "$(cut -f1 <<< "$sel")" || true
  done
}

mod::health_actions() {  # $1 = repo relpath
  local rel="$1" dir="$CODE_ROOT/$1"
  while :; do
    local act
    ui::page "Health · inspect" "act on one repo — pull is ff-only and skips dirty trees" "$rel"
    act="$(ui::menu "💚 $rel" \
          "🦎  Open lazygit" "📋  git status" "⇣  Fetch (with prune)" "⇩  Pull (ff-only)" \
          "✨  Create develop branch" "🧹  Cleanup branches" "←  Back")" || return 0
    case "$act" in
      *lazygit*)
        if command -v lazygit >/dev/null; then ( cd "$dir" && lazygit )
        elif fix::offer "lazygit isn't installed — it powers this shortcut." \
                        "brew install lazygit" "command -v lazygit"; then
          ( cd "$dir" && lazygit )
        fi ;;
      *status*)   ( git -C "$dir" -c color.status=always status | less -R ) || true ;;
      *Fetch*)
        if ui::spin "Fetching ${rel}…" git -C "$dir" fetch --prune; then ui::toast ok "fetched"
        else ui::toast err "fetch failed"; fi
        ;;
      *Pull*)
        if [ "$(git::dirty_count "$dir")" -gt 0 ]; then ui::toast warn "dirty working tree — skipped (commit or stash first)"
        elif ui::spin "Pulling ${rel}…" git -C "$dir" pull --ff-only; then ui::toast ok "pulled"
        else ui::toast err "pull failed (diverged?)"; fi
        ;;
      *develop*)
        if git::has_branch "$dir" develop; then ui::toast warn "develop already exists"
        else
          if git -C "$dir" branch develop; then
            ui::toast ok "develop created (push it: git push -u origin develop)"
          else ui::toast err "could not create develop"; fi
        fi
        ;;
      *Cleanup*)  mod::cleanup "$rel" || true ;;
      *) return 0 ;;
    esac
  done
}

# ---------------------------------------------------------------- mod::cleanup
mod::cleanup() {
  local rel="${1:-}"
  if [ -z "$rel" ]; then
    local repos=() r
    while IFS= read -r r; do [ -n "$r" ] && repos+=("$r"); done < <(disco::local_repos)
    [ "${#repos[@]}" -eq 0 ] && { log::warn "no local repos found"; return 0; }
    if ! ui::is_interactive; then log::err "cleanup is interactive-only (pass a repo path arg)"; return 1; fi
    rel="$(printf '%s\n' "${repos[@]}" | ui::pick --header="pick repo to clean · type to search · enter select · esc back")" || return 0
    [ -z "$rel" ] && return 0
  fi
  # validate the path shape (also blocks ../ escapes from a CLI arg)
  path::parse "$rel" || { log::err "not a repo path under $CODE_ROOT: $rel (expected <provider>/<org>[/<project>]/<repo>)"; return 1; }
  local dir="$CODE_ROOT/$rel"
  git::is_repo "$dir" || { log::err "$rel is not a git repo"; return 1; }
  # with a path arg in plain mode the menu below would fail generically and
  # exit 0 having done nothing — fail like the no-arg plain path does (rc 1)
  ui::is_interactive || { log::err "cleanup is interactive-only"; return 1; }

  while :; do
    local act
    ui::page "Cleanup" "branch hygiene for one repo · fetch --prune first for fresh [gone] detection" "$rel"
    act="$(ui::menu "🧹 $rel" \
          "🗑  Prune gone/merged branches" "⇅  Sync develop ← main" \
          "⇣  Fetch --prune first" "←  Back")" || return 0
    case "$act" in
      *Prune*)  cleanup::prune_branches "$dir" || true ;;
      *Sync*)   cleanup::sync_develop "$dir" || true ;;
      *Fetch*)
        if ui::spin "Fetching with prune…" git -C "$dir" fetch --prune; then ui::toast ok "fetched + pruned"
        else ui::toast err "fetch failed"; fi
        ;;
      *) return 0 ;;
    esac
  done
}

cleanup::prune_branches() {  # $1 = repo dir
  local dir="$1" cur target
  cur="$(git::current_branch "$dir")"
  if git::has_branch "$dir" develop; then target=develop; else target=main; fi
  local lines=() name up class merged badge sel
  while IFS=$'\t' read -r name up class; do
    [ "$name" = main ] || [ "$name" = master ] || [ "$name" = develop ] || [ "$name" = "$cur" ] || {
      merged=0; git::merged_into "$dir" "$name" "$target" && merged=1
      badge=""
      [ "$class" = "gone" ] && badge="${A_REDX}[gone]${A_RST}"
      [ "$merged" = "1" ] && badge="$badge ${A_GREEN}[merged→$target]${A_RST}"
      [ "$class" = "local" ] && badge="$badge ${A_DIM}[no upstream]${A_RST}"
      if [ "$class" = "gone" ] && [ "$merged" = "0" ]; then
        badge="$badge ${A_YELLOW}${G_WARN} unmerged commits${A_RST}"
      fi
      lines+=("$name	$class	$merged	$(printf '%-32s' "$name") $badge")
      continue
    }
  done < <(git::branch_rows "$dir")
  [ "${#lines[@]}" -eq 0 ] && { ui::toast ok "no prunable branches ($target/main/current are protected)"; return 0; }

  local qdir; printf -v qdir '%q' "$dir"
  ui::page "Cleanup · branches" "select branches to delete · [merged] uses -d (safe) · [gone] unmerged needs explicit confirm" \
    "$(basename "$dir")"
  sel="$(printf '%s\n' "${lines[@]}" | ui::pick --multi \
        --delimiter='\t' --with-nth=4 \
        --bind 'space:toggle+down,ctrl-a:select-all,ctrl-d:deselect-all' \
        --header="type to search · space/tab select · enter confirm · esc back (main/develop/current protected)" \
        --preview "git -C $qdir log --oneline -8 --color=always refs/heads/{1} --" \
        --preview-window='right,45%,border-left')" || return 0
  [ -z "$sel" ] && return 0

  local todelete=() warnlist="" n
  while IFS=$'\t' read -r name class merged _; do
    [ -z "$name" ] && continue
    todelete+=("$name	$class	$merged")
    warnlist="$warnlist
    $name$( [ "$class" = gone ] && [ "$merged" = 0 ] && printf ' %s unmerged — will FORCE delete' "$G_WARN" )"
  done <<< "$sel"
  n="${#todelete[@]}"
  log::warn "about to delete $n local branch(es):$warnlist"
  ui::confirm "This cannot be undone. Delete $n branch(es)?" "Delete $n" || return 0

  local row ok=0 fail=0
  for row in "${todelete[@]}"; do
    IFS=$'\t' read -r name class merged <<< "$row"
    # '--' guards against branch names starting with '-'.
    # merged=1 was verified by US against $target (merge-base --is-ancestor), so -D is
    # safe and avoids -d's different check (merged-into-HEAD/upstream) refusing wrongly.
    if [ "$merged" = "1" ]; then
      git -C "$dir" branch -D -- "$name" >/dev/null 2>&1 && { log::ok "$name deleted (merged into $target)"; ok=$((ok+1)); continue; }
    fi
    if [ "$class" = "gone" ]; then
      git -C "$dir" branch -D -- "$name" >/dev/null 2>&1 && { log::ok "$name force-deleted (was gone)"; ok=$((ok+1)); continue; }
    fi
    if git -C "$dir" branch -d -- "$name" >/dev/null 2>&1; then
      log::ok "$name deleted"; ok=$((ok+1))
    else
      log::err "$name refused (-d) — unmerged and not gone; delete manually with -D if sure"
      fail=$((fail+1))
    fi
  done
  ui::toast ok "$ok deleted, $fail refused"
}

cleanup::sync_develop() {  # $1 = repo dir
  local dir="$1"
  git::has_branch "$dir" develop || { ui::toast err "no develop branch here"; return 1; }
  if [ "$(git::dirty_count "$dir")" -gt 0 ]; then ui::toast err "dirty working tree — commit or stash first"; return 1; fi
  local src="origin/main"
  git -C "$dir" show-ref --verify --quiet refs/remotes/origin/main || src="main"
  [ "$src" = "main" ] && ! git::has_branch "$dir" main && { ui::toast err "no main branch"; return 1; }
  if ui::spin "Syncing develop ← ${src}…" "$SELF" __syncdevelop "$dir" "$src"; then
    ui::toast ok "develop synced ← $src"
  else
    ui::toast err "sync failed (merge conflict? resolve manually)"
  fi
}

# ----------------------------------------------------------------- mod::config
mod::config() {
  local sub="${1:-}"
  if [ "$sub" = "list" ] || ! ui::is_interactive; then
    log::info "config file: $CFG_FILE"
    local k
    for k in code_root extra_orgs_github extra_orgs_gitlab extra_orgs_azure-devops \
             ado_default_org ado_project_map default_visibility exclude_forks_default; do
      printf '  %-26s = %s\n' "$k" "$(cfg::get "$k" "(unset)")"
    done
    return 0
  fi
  while :; do
    local key val
    ui::page "Config" "code root · orgs not yet cloned · ADO org:project map · repo-create visibility · fork filter" "$CFG_FILE"
    key="$(ui::menu "🔧 config · $CFG_FILE" \
          "code_root" "extra_orgs_github" "extra_orgs_azure-devops" "extra_orgs_gitlab" \
          "ado_default_org" "ado_project_map" "default_visibility" \
          "exclude_forks_default" "📄  show all" "←  Back")" || return 0
    case "$key" in
      *show*) mod::config list; ui::is_interactive && { printf '  (enter to continue) '; read -r || true; } ;;
      *Back*) return 0 ;;
      *)
        local ph='comma-separated / org:project'
        # shellcheck disable=SC2088  # 'code_root' placeholder is literal hint text — ~ never expands
        case "$key" in
          default_visibility) ph='private|public' ;;
          code_root)          ph='~/Code' ;;
        esac
        val="$(ui::input "$key (current: $(cfg::get "$key" "unset"))" "$ph")" || continue
        [ -z "$val" ] && continue
        if [ "$key" = "default_visibility" ] && [ "$val" != private ] && [ "$val" != public ]; then
          ui::toast err "must be 'private' or 'public'"; continue
        fi
        if [ "$key" = "exclude_forks_default" ] && [ "$val" != true ] && [ "$val" != false ]; then
          ui::toast err "must be 'true' or 'false'"; continue
        fi
        if [ "$key" = "code_root" ]; then
          local exp; exp="$(path::expand_tilde "$val")"
          if [ ! -d "$exp" ]; then
            if ui::confirm "$exp does not exist — create it?" "Create"; then
              mkdir -p "$exp" || { ui::toast err "could not create $exp"; continue; }
            else ui::toast warn "code_root not changed"; continue; fi
          fi
        fi
        cfg::set "$key" "$val"
        # a code_root change must re-point the LIVE process too (bootstrap
        # honors the env pin) — health/sync in this same session would
        # otherwise keep using the old tree until a restart
        [ "$key" = "code_root" ] && cfg::bootstrap
        ui::toast ok "$key = $val"
        ;;
    esac
  done
}

