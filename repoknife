${H}  CONCEPTS${R}
    Folder convention   ${D}~/Code/github/<org>/<repo>${R}
                        ${D}~/Code/gitlab/<org>/<project>/<repo>      ("No Project" when no subgroup)${R}
                        ${D}~/Code/azure-devops/<org>/<project>/<repo>${R}
    Gitflow defaults    ${D}main + develop · develop is the default branch · feature→develop
                        squash-merge · develop→main merge commit · long-lived branches
                        are never auto-deleted${R}
    Orgs                ${D}auto-discovered from folders ∪ config extra_orgs_* keys${R}
    Cache               ${D}remote repo lists cached 1h in ~/.cache/repoknife — bypass with --refresh${R}

${H}  KEYS — every list screen${R}
    ${G}type to search${R}      ${D}fuzzy filter as you type (fzf) — no prefix key needed${R}
    enter               ${D}select / open actions${R}
    esc                 ${D}always one level up — never further${R}
${H}  KEYS — multi-select screens (sync · init · cleanup)${R}
    space or tab        ${D}toggle item and move down${R}
    ctrl-a / ctrl-d     ${D}select all / deselect all${R}

${H}  SCREENS${R}
    ✨ Init             ${D}plain folder → git init main → commit → develop (checked out) →
                        optional GitHub remote (private/public) with develop as default${R}
    🔁 Sync             ${D}pick provider → org → repos · clones missing, pulls cloned (ff-only)
                        ${Y}dirty repos are skipped, never touched${R}${D} · forks badged ⑂ (--no-forks hides)
                        clone lines show live git progress (%, MiB, speed)${R}
    🔀 PRs              ${D}scopes: all involving me · authored · review-requested · assigned ·
                        mentioned · actions: checkout / diff / approve / merge / browser
                        merge follows gitflow (squash→develop, merge-commit→main)${R}
    🤖 Actions          ${D}recent workflow runs · watch live · re-run failed · failure logs${R}
    💚 Health           ${D}every local repo worst-first: dirty · diverged · behind/ahead ·
                        gone branches · missing develop · enter → lazygit/fetch/pull/fix${R}
    🧹 Cleanup          ${D}delete [gone]/[merged] branches (main·develop·current protected) ·
                        sync develop ← main${R}
    🔧 Config           ${D}$CFG_FILE${R}

${H}  TROUBLESHOOTING${R}
    gh not authed       ${D}gh auth login${R}
    Actions re-run 403  ${D}gh auth refresh -s workflow   (token needs the workflow scope)${R}
    Azure DevOps        ${D}az login   (or az devops login for a PAT)${R}
    Commit signing      ${D}check git config user.signingkey + gpg.format
                        macOS: ssh-add --apple-load-keychain${R}
    Plain mode / CI     ${D}--plain or pipe output · health --exit-code gates CI${R}
    Self-diagnostics    ${D}repoknife _selftest${R}

${F}  full CLI reference: repoknife --help${R}
EOF
}

mod::help() {
  if ui::is_interactive; then
    help::page | less -R
  else
    help::page | ui::strip_ansi
  fi
}

#============================================================================
# SECTION 12 — CLI DISPATCH, MENU, CHECKS, SELFTEST, MAIN
#============================================================================
deps::check() {
  local missing=() t
  for t in fzf jq gh git; do command -v "$t" >/dev/null || missing+=("$t"); done
  if ui::is_interactive; then
    command -v gum >/dev/null || missing+=(gum)
  fi
  [ "${#missing[@]}" -eq 0 ] && return 0
  printf '\n  repoknife needs a couple of tools:\n\n' >&2
  for t in git fzf jq gh gum az; do
    if command -v "$t" >/dev/null; then printf '    %s %s' "$G_OK" "$t" >&2; else printf '    %s %s' "$G_FAIL" "$t" >&2; fi
  done
  printf '\n\n  Missing: %s\n' "${missing[*]}" >&2
  if [ "$OS" = "Darwin" ]; then printf '    brew install %s\n\n' "${missing[*]}" >&2
  else printf '    see install notes (apt/brew) for: %s\n\n' "${missing[*]}" >&2; fi
  exit 1
}

auth::check_gh() {
  gh auth status >/dev/null 2>&1 && return 0
  log::err "GitHub CLI is not authenticated. Run: gh auth login   — then retry."
  return 2
}

auth::has_workflow_scope() {
  gh auth status 2>&1 | grep -q "workflow"
}

menu::counts() {
  local repos orgs provs dirtytxt=""
  repos="$(disco::local_repos | wc -l | tr -d ' ')"
  orgs="$( { disco::orgs github; disco::orgs azure-devops; disco::orgs gitlab; } | wc -l | tr -d ' ')"
  provs="$(disco::providers | wc -l | tr -d ' ')"
  if [ -f "$CACHE_DIR/counts.json" ]; then
    local at dirty attention
    at="$(jq -r '.at' "$CACHE_DIR/counts.json" 2>/dev/null || echo 0)"
    dirty="$(jq -r '.dirty' "$CACHE_DIR/counts.json" 2>/dev/null || echo '?')"
    attention="$(jq -r '.attention' "$CACHE_DIR/counts.json" 2>/dev/null || echo '?')"
    dirtytxt=" · $G_DIRTY $dirty dirty · $G_WARN $attention attention (cache $(ui::age "$at") ago)"
  else
    dirtytxt=" · (run health for status)"
  fi
  printf '📁 %s repos · %s orgs · %s providers%s' "$repos" "$orgs" "$provs" "$dirtytxt"
}

menu::loop() {
  ui::banner
  while :; do
    gum style --foreground "$C_DIM" --margin "0 0 1 2" "$(menu::counts)"
    local choice
    choice="$(ui::menu "" \
      "✨  Init       turn plain folders into gitflow repos" \
      "🔁  Sync       fetch + clone/pull repos from a provider" \
      "🔀  PRs        cross-repo pull-request dashboard" \
      "🤖  Actions    workflow runs · watch · rerun" \
      "💚  Health     scan every local repo for problems" \
      "🧹  Cleanup    prune gone/merged branches · sync develop" \
      "🔧  Config     orgs · ADO defaults · fork filter" \
      "📖  Help       keys · concepts · troubleshooting" \
      "👋  Quit")" || return 0
    case "$choice" in
      *Sync*)    mod::sync    || true ;;
      *PRs*)     mod::pr      || true ;;
      *Actions*) mod::runs    || true ;;
      *Health*)  mod::health  || true ;;
      *Cleanup*) mod::cleanup || true ;;
      *Init*)    mod::init    || true ;;
      *Config*)  mod::config  || true ;;
      *Help*)    mod::help    || true ;;
      *) return 0 ;;
    esac
  done
}

cli::help() {
  cat <<EOF

   ╠══►  REPOKNIFE v$VERSION   a git-repos swiss-army-knife · by Florian Grousset

  USAGE
    repoknife                     launch interactive menu
    repoknife <command> [args] [flags]

  COMMANDS
    init                          gitflow-init plain folders (+ optional remote)
